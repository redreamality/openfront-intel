---
import { getLangFromUrl, useTranslations, pickI18n, type I18nBundle } from '../i18n';

export interface UnitRow {
  id: string;
  enName?: string;
  category: string;
  cost: number;
  maxHealth: number | null;
  damage: number | null;
  constructionDuration: number | null;
  upgradable: boolean;
  i18n: Partial<Record<'en' | 'fr' | 'nl' | 'de' | 'zh', I18nBundle>>;
}
export interface Props {
  units: UnitRow[];
  showCategory?: boolean;
}
const { units, showCategory = true } = Astro.props as Props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const categoryLabel: Record<string, string> = {
  ship: t('db.category.ship'),
  projectile: t('db.category.projectile'),
  nuke: t('db.category.nuke'),
  structure: t('db.category.structure'),
};
const fmtNum = (n: number | null) => (n == null ? '—' : n.toLocaleString('en-US'));
---

<div class="overflow-x-auto rounded border border-iron-800">
  <table class="data-table">
    <thead>
      <tr>
        <th class="min-w-[7rem]">{t('unit.col.name')}</th>
        {showCategory && <th>{t('unit.col.category')}</th>}
        <th class="min-w-[10rem]">{t('unit.col.cost')}</th>
        <th>HP</th>
        <th>{t('unit.col.damage')}</th>
        <th>{t('unit.col.build')}</th>
        <th>{t('unit.col.upgrade')}</th>
        <th class="min-w-[16rem]">{t('unit.col.role')}</th>
      </tr>
    </thead>
    <tbody>
      {units.map((u) => {
        const tx = pickI18n(u, lang);
        return (
          <tr id={`u-${u.id}`}>
            <td>
              <div class="font-semibold text-iron-50">{tx.name ?? u.id}</div>
              {u.enName && lang !== 'en' && (
                <div class="text-xs text-iron-500 font-mono">{u.enName}</div>
              )}
            </td>
            {showCategory && (
              <td><span class="tag-chip">{categoryLabel[u.category] ?? u.category}</span></td>
            )}
            <td>
              <div class="font-mono text-cannon-400">{u.cost > 0 ? u.cost.toLocaleString('en-US') : t('unit.free')}</div>
              <div class="mt-1 text-xs text-iron-400 leading-snug">{tx.costFormula}</div>
            </td>
            <td class="font-mono text-iron-200">{fmtNum(u.maxHealth)}</td>
            <td class="font-mono text-iron-200">{fmtNum(u.damage)}</td>
            <td class="font-mono text-iron-200">{u.constructionDuration == null ? '—' : `${u.constructionDuration}t`}</td>
            <td>
              {u.upgradable ? (
                <span class="text-military-300">{t('unit.upgradable')}</span>
              ) : (
                <span class="text-iron-500">—</span>
              )}
            </td>
            <td>
              <div class="text-iron-200">{tx.role}</div>
              {tx.notes && tx.notes.length > 0 && (
                <ul class="mt-1 list-disc pl-4 text-xs text-iron-400 space-y-0.5">
                  {tx.notes.map((n) => <li>{n}</li>)}
                </ul>
              )}
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
