---
import { getLangFromUrl, useTranslations, pickI18n, type I18nBundle, type Lang } from '../i18n';

export interface MapItem {
  id: string;
  enName?: string;
  category: string;
  i18n: Partial<Record<Lang, I18nBundle>>;
}
export interface MapGroup {
  key: string;
  label: string;
  desc: string;
  items: MapItem[];
}
export interface Props {
  groups: MapGroup[];
}
const { groups } = Astro.props as Props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="space-y-12">
  {groups.map((g) => (
    <section id={`cat-${g.key.toLowerCase()}`}>
      <header class="mb-4 flex flex-wrap items-baseline justify-between gap-3 border-b border-iron-800 pb-2">
        <h2 class="text-xl font-semibold text-iron-50">
          {g.label}
          <span class="ml-2 text-sm font-normal text-iron-500">{g.items.length} {t('map.count')}</span>
        </h2>
        <p class="text-sm text-iron-400">{g.desc}</p>
      </header>
      <ul class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {g.items.map((m) => {
          const mt = pickI18n(m, lang);
          const name = mt.name ?? m.enName ?? m.id;
          return (
            <li class="rounded border border-iron-800 bg-iron-900/40 px-3 py-2 transition-colors hover:border-cannon-600/60 hover:bg-iron-900/70">
              <div class="text-sm font-medium text-iron-50">{name}</div>
              {m.enName && lang !== 'en' && name !== m.enName && (
                <div class="text-xs text-iron-500 font-mono">{m.enName}</div>
              )}
            </li>
          );
        })}
      </ul>
    </section>
  ))}
</div>
