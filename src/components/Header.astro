---
import Nav from './Nav.astro';
import LanguagePicker from './LanguagePicker.astro';
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const homeHref = lang === 'en' ? base : `${base}${lang}/`;
---

<header class="sticky top-0 z-40 border-b border-iron-800 bg-iron-950/85 backdrop-blur supports-[backdrop-filter]:bg-iron-950/70">
  <div class="container-wide flex h-14 items-center justify-between gap-6">
    <a href={homeHref} class="flex items-center gap-2 text-sm font-semibold tracking-wide text-iron-50">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded border border-cannon-600/60 bg-iron-900 text-cannon-400 font-mono">⌖</span>
      <span class="hidden sm:inline">{t('site.title')}</span>
      <span class="sm:hidden">OF Intel</span>
    </a>
    <div class="flex items-center gap-4">
      <Nav lang={lang} />
      <LanguagePicker />
    </div>
  </div>
</header>
