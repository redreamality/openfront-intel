---
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const langPrefix = lang === 'en' ? '' : `${lang}/`;
---

<footer class="mt-24 border-t border-iron-800 bg-iron-950/80 py-10 text-sm text-iron-400">
  <div class="container-wide grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <div class="text-iron-100 font-semibold">{t('footer.title')}</div>
      <p class="mt-2 text-iron-400 leading-relaxed">{t('footer.description')}</p>
    </div>
    <div>
      <div class="text-iron-100 font-semibold">{t('footer.navigation')}</div>
      <ul class="mt-2 space-y-1">
        <li><a class="nav-link" href={`${base}${langPrefix}mechanics/`}>{t('nav.mechanics')}</a></li>
        <li><a class="nav-link" href={`${base}${langPrefix}database/`}>{t('nav.database')}</a></li>
        <li><a class="nav-link" href={`${base}${langPrefix}strategies/`}>{t('nav.strategies')}</a></li>
        <li><a class="nav-link" href={`${base}${langPrefix}changelog/`}>{t('nav.changelog')}</a></li>
      </ul>
    </div>
    <div>
      <div class="text-iron-100 font-semibold">{t('footer.sources')}</div>
      <ul class="mt-2 space-y-1">
        <li><a class="nav-link" href="https://openfront.io/" rel="noopener" target="_blank">{t('footer.official')}</a></li>
        <li><a class="nav-link" href="https://github.com/openfrontio/OpenFrontIO" rel="noopener" target="_blank">{t('footer.github')}</a></li>
        <li><a class="nav-link" href={`${base}${langPrefix}about/`}>{t('nav.about')}</a></li>
      </ul>
    </div>
    <div>
      <div class="text-iron-100 font-semibold">{t('footer.disclaimer')}</div>
      <p class="mt-2 leading-relaxed">{t('footer.disclaimer.text')}</p>
    </div>
  </div>
  <div class="container-wide mt-8 flex flex-col gap-2 border-t border-iron-800 pt-4 text-xs text-iron-500 sm:flex-row sm:items-center sm:justify-between">
    <span>© {year} {t('footer.copyright')}</span>
    <span class="font-mono">made with Astro</span>
  </div>
</footer>
