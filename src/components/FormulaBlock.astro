---
import { getLangFromUrl, pickI18n, type I18nBundle, type Lang } from '../i18n';

type StringOrI18n = string | { i18n?: Partial<Record<Lang, I18nBundle>> };
type ItemInput = { name: string; expr: string } | { i18n?: Partial<Record<Lang, I18nBundle>> };

export interface Props {
  label: StringOrI18n;
  items: ItemInput[];
}
const { label, items } = Astro.props as Props;
const lang = getLangFromUrl(Astro.url);

function resolveLabel(l: StringOrI18n): string {
  if (typeof l === 'string') return l;
  if (l && typeof l === 'object' && 'i18n' in l) return pickI18n(l, lang).label ?? '';
  return '';
}
function resolveItem(it: ItemInput): { name: string; expr: string } {
  if ('i18n' in it) {
    const tx = pickI18n(it, lang);
    return { name: tx.name ?? '', expr: tx.expr ?? '' };
  }
  return it;
}

const resolvedLabel = resolveLabel(label);
const resolvedItems = items.map(resolveItem);
---

<section class="my-6 rounded border border-iron-800 bg-iron-900/40">
  <header class="border-b border-iron-800 px-4 py-2 text-sm font-semibold text-cannon-400">{resolvedLabel}</header>
  <dl class="divide-y divide-iron-800">
    {resolvedItems.map((it) => (
      <div class="grid grid-cols-1 gap-1 px-4 py-3 sm:grid-cols-[10rem,1fr] sm:gap-4">
        <dt class="text-sm text-iron-300">{it.name}</dt>
        <dd class="font-mono text-sm text-military-200 break-words">{it.expr}</dd>
      </div>
    ))}
  </dl>
</section>
