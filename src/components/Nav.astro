---
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname;
const langPrefix = lang === 'en' ? '' : `/${lang}`;

const links = [
  { href: `${base}${langPrefix}/mechanics/`, label: t('nav.mechanics') },
  { href: `${base}${langPrefix}/database/`, label: t('nav.database') },
  { href: `${base}${langPrefix}/strategies/`, label: t('nav.strategies') },
  { href: `${base}${langPrefix}/guides/`, label: t('nav.guides') },
  { href: `${base}${langPrefix}/changelog/`, label: t('nav.changelog') },
  { href: `${base}${langPrefix}/glossary/`, label: t('nav.glossary') },
];

function isActive(href: string) {
  const trimmed = href.replace(/\/$/, '');
  if (trimmed === base) return pathname === base + '/' || pathname === base;
  return pathname.startsWith(trimmed);
}
---

<nav aria-label="主导航">
  <ul class="flex items-center gap-3 sm:gap-5 text-sm">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class:list={["nav-link", isActive(link.href) ? 'active' : '']}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
