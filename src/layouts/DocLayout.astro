---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedContent from '../components/RelatedContent.astro';
import { getLangFromUrl, useTranslations, getIntlLocale } from '../i18n';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  difficulty?: string;
  category?: string;
  collection?: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  related?: Array<{ href: string; title: string; description?: string; date?: Date }>;
  eyebrow?: string;
}
const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  difficulty,
  category,
  collection,
  headings = [],
  related = [],
  eyebrow,
} = Astro.props as Props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const fmt = (d?: Date) => (d ? new Intl.DateTimeFormat(getIntlLocale(lang), { dateStyle: 'medium' }).format(d) : '');
---

<BaseLayout title={title} description={description}>
  <article class="container-wide pt-12 pb-20 lg:pr-64">
    <header class="border-b border-iron-800 pb-6 mb-8">
      {eyebrow && <p class="tag-chip">{eyebrow}</p>}
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-iron-50">{title}</h1>
      {description && <p class="mt-3 text-base text-iron-300 leading-relaxed max-w-3xl">{description}</p>}
      <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-iron-400">
        {category && <span class="tag-chip">{category}</span>}
        {difficulty && <span class="tag-chip">{t('doc.difficulty')} · {difficulty}</span>}
        {pubDate && <span class="font-mono">{t('doc.pubDate')} {fmt(pubDate)}</span>}
        {updatedDate && <span class="font-mono">{t('doc.updatedDate')} {fmt(updatedDate)}</span>}
        {tags.length > 0 && tags.map((tag) => <span class="text-iron-500">#{tag}</span>)}
      </div>
    </header>

    <div class="prose prose-invert max-w-none prose-headings:scroll-mt-20 prose-h2:border-b prose-h2:border-iron-800 prose-h2:pb-1 prose-h2:text-iron-50 prose-h3:text-iron-100 prose-a:text-cannon-400 prose-code:text-military-300 prose-pre:bg-iron-950 prose-pre:border prose-pre:border-iron-800">
      <slot />
    </div>

    <RelatedContent items={related} />
  </article>
  <TableOfContents headings={headings} />
</BaseLayout>
