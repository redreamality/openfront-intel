---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { byLang, stripLangPrefix } from '../../i18n';

const LANG = 'en';
const base = import.meta.env.BASE_URL;
const all = (await getCollection('guides', ({ data }) => !data.draft))
  .filter(byLang(LANG))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = (d: Date) => new Intl.DateTimeFormat('en-US', { dateStyle: 'medium' }).format(d);
---

<BaseLayout title="Guides" description="OpenFront.io beginner to advanced tutorials, UI walkthrough, and hotkeys.">
  <PageHeader eyebrow="GUIDES" title="Guides" lead="Step-by-step from opening the game to your first successful expansion." />
  <section class="container-wide py-10">
    {all.length === 0 ? (
      <p class="text-iron-400">No guides yet.</p>
    ) : (
      <ul class="space-y-4">
        {all.map((post) => (
          <li>
            <a href={`${base}guides/${stripLangPrefix(post.slug)}/`} class="block card group">
              <div class="flex flex-wrap items-center gap-2 text-xs text-iron-500">
                <span class="tag-chip">{post.data.category ?? 'Guide'}</span>
                {post.data.difficulty && <span class="tag-chip">Difficulty · {post.data.difficulty}</span>}
                <span class="font-mono">{fmt(post.data.pubDate)}</span>
              </div>
              <h2 class="mt-2 text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{post.data.title}</h2>
              <p class="mt-2 text-sm text-iron-300 leading-relaxed">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
