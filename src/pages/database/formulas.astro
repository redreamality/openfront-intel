---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import FormulaBlock from '../../components/FormulaBlock.astro';
import Callout from '../../components/Callout.astro';
import formulas from '../../data/formulas.json';

const groups = Object.entries(formulas.groups);
---

<BaseLayout title="Formula Reference" description="OpenFront.io combat, population, economy, nuclear, and alliance core formulas.">
  <PageHeader eyebrow="DATABASE / FORMULAS" title="Formula Reference" lead="No derivations, just conclusions. All formulas can be found in OpenFrontIO/src/core/configuration/Config.ts." />
  <section class="container-wide py-10 space-y-6">
    <Callout type="warn" title="Reading Notes">
      <p>Formulas use in-game variable names (<code class="font-mono">tick</code>, <code class="font-mono">tiles</code>, <code class="font-mono">troops</code>).</p>
      <p>10 ticks ≈ 1 second. Constant <code class="font-mono">DEFENSE_DEBUFF_MIDPOINT = 150,000 tiles</code> from source.</p>
    </Callout>
    {groups.map(([key, group]) => (
      <FormulaBlock label={group.label} items={group.items} />
    ))}
  </section>
</BaseLayout>
