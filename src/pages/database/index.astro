---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import meta from '../../data/_meta.json';
import maps from '../../data/maps.json';
import units from '../../data/units.json';
import structures from '../../data/structures.json';

const base = import.meta.env.BASE_URL;
const sections = [
  { href: `${base}database/units/`, title: 'Units Database', desc: `All ${units.length} units / vehicles / projectiles with cost formulas and notes.` },
  { href: `${base}database/structures/`, title: 'Structures Database', desc: `${structures.length} structures with upgrade info, build times, and unlock conditions.` },
  { href: `${base}database/formulas/`, title: 'Formula Reference', desc: 'Core formulas for combat, troop cap, gold income, and SAM range.' },
  { href: `${base}database/maps/`, title: 'Map List', desc: `${maps.meta.total} maps by category: Continental / Regional / Fantasy / Arcade / Tournament.` },
];
---

<BaseLayout title="Database" description="OpenFront.io units, structures, maps, and formula reference.">
  <PageHeader eyebrow="DATABASE" title="Database" lead="All values synced from game source code—use as quick reference during matches." />
  <section class="container-wide py-10">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {sections.map((s) => (
        <a href={s.href} class="card group block">
          <h2 class="text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{s.title}</h2>
          <p class="mt-3 text-sm text-iron-300 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
    <p class="mt-10 text-xs text-iron-500 font-mono">Data updated: {meta.generatedAt} · Source {meta.source.replace(/^.*OpenFrontIO.*/, 'OpenFrontIO ' + meta.upstreamVersion)}</p>
  </section>
</BaseLayout>
