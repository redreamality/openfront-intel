---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import UnitTable from '../../components/UnitTable.astro';
import Callout from '../../components/Callout.astro';
import structures from '../../data/structures.json';
---

<BaseLayout title="Structures Database" description="City, Port, Factory, DefensePost, SAM, MissileSilo detailed parameters.">
  <PageHeader eyebrow="DATABASE / STRUCTURES" title="Structures Database" lead="6 structures with costs, build times, and upgrade characteristics. Most building costs scale with quantity." />
  <section class="container-wide py-10 space-y-8">
    <Callout type="tip" title="Cost Scaling">
      <p>Cost formula <code class="font-mono">min(1M, 2^n × 125k)</code> means first 4 City/Port/Factory cost 125k → 250k → 500k → 1M, then capped.</p>
      <p>Ports and Factories <strong>share the same counter</strong> (PortBuildableGroup), so build order affects both prices.</p>
    </Callout>
    <UnitTable units={structures} showCategory={false} />

    <section class="rounded border border-iron-800 bg-iron-900/40 p-5 text-sm leading-relaxed">
      <h2 class="text-base font-semibold text-cannon-400">Upgrade Tiers (4 levels)</h2>
      <ul class="mt-3 space-y-2 text-iron-300">
        <li><strong>City</strong> — Each level <code class="font-mono">+250,000</code> troop cap; high-level cities with Factory significantly boost train revenue.</li>
        <li><strong>Port</strong> — Higher level = better <strong>trade ship spawn rate and cap revenue</strong> (v24 balance for 150 global cap).</li>
        <li><strong>SAM Launcher</strong> — Range from default 70 up to ~150 tiles, formula <code class="font-mono">150 − 480/(level+5)</code>.</li>
        <li><strong>Missile Silo</strong> — Upgrades reduce nuke reload time; AI avoids SAM-covered targets.</li>
        <li><strong>Factory</strong> — Improves train spawn rate and railway throughput.</li>
      </ul>
    </section>
  </section>
</BaseLayout>
