---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import UnitTable from '../../components/UnitTable.astro';
import Callout from '../../components/Callout.astro';
import structures from '../../data/structures.json';
---

<BaseLayout title="建筑数据库" description="City、Port、Factory、DefensePost、SAM、MissileSilo 详细参数。">
  <PageHeader eyebrow="DATABASE / STRUCTURES" title="建筑数据库" lead="6 种结构的成本、建造时间与升级特性。多数建筑成本随数量上升。" />
  <section class="container-wide py-10 space-y-8">
    <Callout type="tip" title="建造成本节流">
      <p>成本公式 <code class="font-mono">min(1M, 2^n × 125k)</code> 意味着前 4 座 City/Port/Factory 价格分别为 125k → 250k → 500k → 1M，之后封顶。</p>
      <p>港口与工厂 <strong>共享同一计数</strong>（PortBuildableGroup），先后顺序会互相影响价格。</p>
    </Callout>
    <UnitTable units={structures} showCategory={false} />

    <section class="rounded border border-iron-800 bg-iron-900/40 p-5 text-sm leading-relaxed">
      <h2 class="text-base font-semibold text-cannon-400">升级阶梯（4 级）</h2>
      <ul class="mt-3 space-y-2 text-iron-300">
        <li><strong>City</strong> — 每级 <code class="font-mono">+250,000</code> 部队上限；高等级城市配合 Factory 可显著提升火车收益。</li>
        <li><strong>Port</strong> — 等级越高，<strong>贸易船生成率与上限收益</strong>越高（v24 平衡补偿 150 全局上限）。</li>
        <li><strong>SAM Launcher</strong> — 射程从默认 70 提升至接近 150 tiles，公式 <code class="font-mono">150 − 480/(level+5)</code>。</li>
        <li><strong>Missile Silo</strong> — 升级降低核弹装填时间；AI 会避开 SAM 覆盖的目标。</li>
        <li><strong>Factory</strong> — 提升火车生成率与铁路网吞吐。</li>
      </ul>
    </section>
  </section>
</BaseLayout>
