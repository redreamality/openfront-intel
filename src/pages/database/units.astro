---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import UnitTable from '../../components/UnitTable.astro';
import Callout from '../../components/Callout.astro';
import units from '../../data/units.json';

type Unit = (typeof units)[number];
const groups: Array<{ key: Unit['category']; label: string; desc: string }> = [
  { key: 'structure', label: 'Structures', desc: 'Buildable structures, some upgradable for enhanced stats.' },
  { key: 'ship', label: 'Ships / Vehicles', desc: 'Sea and land transport and combat units, including trains and trade ships.' },
  { key: 'nuke', label: 'Nuclear Weapons', desc: 'Atom bombs, hydrogen bombs, MIRVs: costs and blast radii.' },
  { key: 'projectile', label: 'Projectiles', desc: 'Projectiles automatically fired by structures/units.' },
];
---

<BaseLayout title="Units Database" description="All 16 OpenFront.io units / structures / vehicles / projectiles with stats.">
  <PageHeader eyebrow="DATABASE / UNITS" title="Units Database" lead="Grouped by category with cost formulas, HP, damage, and build times. Click row anchors to share direct links." />
  <section class="container-wide py-10 space-y-12">
    <Callout type="spec" title="Reading Convention">
      <p>Cost column shows <strong>current unit price</strong> on top, <strong>cost formula</strong> below (n usually means units already built).</p>
      <p>Build duration is in <code>ticks</code>. OpenFront.io runs at ~<strong>10 ticks/second</strong>.</p>
      <p>"Upgradable" structures can be invested in to increase level, improving stats (e.g., SAM range, city troop cap).</p>
    </Callout>

    {groups.map((g) => {
      const items = units.filter((u) => u.category === g.key);
      if (items.length === 0) return null;
      return (
        <section id={`group-${g.key}`}>
          <header class="mb-4 flex flex-wrap items-baseline justify-between gap-3 border-b border-iron-800 pb-2">
            <h2 class="text-xl font-semibold text-iron-50">{g.label} <span class="text-sm text-iron-500">· {items.length}</span></h2>
            <p class="text-sm text-iron-400">{g.desc}</p>
          </header>
          <UnitTable units={items} showCategory={false} />
        </section>
      );
    })}
  </section>
</BaseLayout>
