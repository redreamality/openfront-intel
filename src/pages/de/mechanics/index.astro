---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';

const base = import.meta.env.BASE_URL;
const langPrefix = 'de/';
const sections = [
  { href: `${base}${langPrefix}mechanics/basics/`, title: 'Grundlagen: Spawn und Expansion', desc: 'Spawn-Immunität, Phasenlänge, frühe Entscheidungsmuster.', tag: 'Grundlagen' },
  { href: `${base}${langPrefix}mechanics/economy/`, title: 'Wirtschaft: Gold, Handel und Bevölkerung', desc: 'Basis-Gold, City-Truppen, Handelsschiffe, Zug-Einnahmen.', tag: 'Wirtschaft' },
  { href: `${base}${langPrefix}mechanics/military/`, title: 'Militär: Angriff, Verteidigung, Kampf', desc: 'Geländekoeffizienten, DefensePost, Bevölkerungsdebuffs, Verratsstrafe.', tag: 'Kampf' },
  { href: `${base}${langPrefix}mechanics/structures/`, title: 'Gebäude: 6 Kernstrukturen', desc: 'City / Port / Factory / DefensePost / SAM / Silo.', tag: 'Gebäude' },
  { href: `${base}${langPrefix}mechanics/units/`, title: 'Einheiten: Schiffe, Züge und Geschosse', desc: 'Transportschiff, Kriegsschiff, Handelsschiff, Zug, Shell/SAM-Rakete.', tag: 'Einheiten' },
  { href: `${base}${langPrefix}mechanics/nukes/`, title: 'Atomwaffen und SAM', desc: 'AtomBomb / HydrogenBomb / MIRV und das SAM-Abwehrnetz.', tag: 'Nuklear' },
  { href: `${base}${langPrefix}mechanics/alliances/`, title: 'Bündnisse und Verrat', desc: '5-Minuten-Bündnisse, automatisches Embargo, Verratsdebuffs 0,5×0,8.', tag: 'Diplomatie' },
  { href: `${base}${langPrefix}mechanics/trains/`, title: 'Züge und Schienen', desc: 'Neues v24-System: Fabrik → Zug → städtisches Handelsnetz.', tag: 'Neu in v24' },
  { href: `${base}${langPrefix}mechanics/trade/`, title: 'Handelssystem', desc: 'Handelsschiff-Cap 150, Entfernungseinkommen, Embargo-Mercy-Timer.', tag: 'Wirtschaft' },
  { href: `${base}${langPrefix}mechanics/modes/`, title: 'Spielmodi im Überblick', desc: 'FFA / Duos / Trios / Quads / Team / Tournament.', tag: 'Übersicht' },
];
---

<BaseLayout title="Spielmechaniken" description="Alle Kernmechaniken von OpenFront.io: 10 thematische Kapitel von Spawn bis Nuklearkrieg.">
  <PageHeader eyebrow="MECHANIK" title="Spielmechaniken" lead="Nach System gegliederte 10 Kapitel; alle Werte aus dem v24-Quellcode. Empfohlener Start: «Grundlagen» und «Wirtschaft»." />
  <section class="container-wide py-10">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sections.map((s, i) => (
        <a href={s.href} class="card group block">
          <div class="flex items-center justify-between text-xs">
            <span class="font-mono text-iron-500">{String(i + 1).padStart(2, '0')}</span>
            <span class="tag-chip">{s.tag}</span>
          </div>
          <h2 class="mt-3 text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{s.title}</h2>
          <p class="mt-2 text-sm text-iron-300 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
