---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import UnitTable from '../../../components/UnitTable.astro';
import Callout from '../../../components/Callout.astro';
import units from '../../../data/units.json';

const mobile = units.filter((u) => u.category !== 'structure' && u.category !== 'nuke');
---

<BaseLayout title="Einheiten: Schiffe, Züge und Geschosse" description="Rollen und Interaktionen der OpenFront.io-Einheiten: Transportschiff, Kriegsschiff, Handelsschiff, Zug, Shell, SAM-Rakete.">
  <PageHeader eyebrow="MECHANIK · 05" title="Einheiten: Schiffe, Züge und Geschosse" lead="Bewegliche Einheiten, die keine Gebäude und keine Atomwaffen sind. Schiffe und Züge bestimmen den «Verkehrsfluss» auf der Karte, Geschosse die unmittelbare Feuerkraft." />
  <article class="container-prose py-10 prose prose-invert max-w-none">
    <UnitTable units={mobile} showCategory={true} />

    <h2>TransportShip — das Landungsboot</h2>
    <ul>
      <li>Kostenloses Spawn, aber <strong>transportiert eigene Truppen</strong>; im Kern werden Bevölkerung übers Meer geschickt.</li>
      <li>Kann durch Kriegsschiffe abgefangen werden; seit v24 kühlt ein Kriegsschiff nach einem Treffer auf das Transportschiff sofort ab — eine Patrouille kann eine ganze Flotte abschlachten.</li>
      <li>Bei aktivem Wassernuke (isWaterNukes) drohen zusätzlich Nuke-Treffer über Wasser.</li>
    </ul>

    <h2>Warship — die Seefeuerkraft</h2>
    <ul>
      <li>HP 1000, Shell-Schaden 250. Ein Kriegsschiff kann ca. 4–5 Gefechtskontakte überstehen, ohne unter die 750-HP-Sicherheitslinie zu fallen.</li>
      <li>Unter 750 HP zieht es sich automatisch zur Reparatur zurück — nicht hinterherjagen, der Gegner ist im Port schnell wieder voll.</li>
      <li>Preis steigt mit Stückzahl: <code>min(1M, (n+1)×250k)</code>; ab 3 Schiffen nahe der Obergrenze.</li>
    </ul>

    <h2>TradeShip — der Wirtschaftsfluss</h2>
    <ul>
      <li>Pendelt automatisch zwischen Port-Paaren; bei Eroberung wechselt der Besitzer, bei Zerstörung verschwindet das Schiff.</li>
      <li>Globaler Cap 150 (v24); je mehr Ports, desto kürzer die durchschnittliche „Lebensdauer" pro Schiff.</li>
      <li>Manuelles Ablehnen (Embargo) anderer Spieler verlangsamt auch das eigene Spawnen.</li>
    </ul>

    <h2>Train — das Gold-Vehikel mit neuer Mechanik (v24)</h2>
    <ul>
      <li>Wird von der Factory automatisch erzeugt und pendelt entlang der Schienen zwischen City- und Factory-Stationen.</li>
      <li>Geschwindigkeit 2 tiles/tick; Zuglänge konfigurierbar (mehr Waggons = mehr potenzielle Abrechnungen).</li>
      <li>Entscheidend: <strong>Der Gold-Ertrag richtet sich nach der Beziehung zum Stationsbesitzer</strong> — Verbündete 35k / Team 25k / Eigene 10k.</li>
    </ul>

    <h2>Shell / SAMMissile — Munition</h2>
    <ul>
      <li>Shell: 250 Schaden, kann durch Hindernisse blockiert werden. Kriegsschiffe und Küstenverteidigung nutzen sie.</li>
      <li>SAMMissile: Standardgeschwindigkeit 12 tiles/tick; das Vorabschuss-Fenster erfordert <code>nukeReachTick − samReachTick ≥ 0</code>; Atomwaffen mit sehr langer Flugstrecke sind schwerer abzufangen.</li>
    </ul>

    <Callout type="tip" title="Einheiten-Beziehungen in einem Satz">
      <p>Kriegsschiff > Transportschiff; Transportschiff > Küstengarnison; SAM > AtomBomb/HydrogenBomb; MIRV > alle SAMs; Zug ≥ Handelsschiff (in der Reifephase).</p>
    </Callout>
  </article>
</BaseLayout>
