---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404 · Seite nicht gefunden" description="Die angeforderte Seite existiert nicht." noindex={true}>
  <section class="container-wide py-24 text-center">
    <p class="font-mono text-xs uppercase tracking-widest text-iron-500">ERROR · 404</p>
    <h1 class="mt-3 text-5xl font-bold text-cannon-500">Territorium verloren</h1>
    <p class="mt-4 text-iron-300 max-w-md mx-auto leading-relaxed">Die angeforderte Seite existiert nicht oder wurde erobert. Versuchen Sie es über die folgenden Einstiege:</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href={base} class="rounded bg-cannon-600 px-4 py-2 text-sm text-iron-950 hover:bg-cannon-500">Zur Startseite</a>
      <a href={`${base}de/mechanics/`} class="rounded border border-iron-700 px-4 py-2 text-sm text-iron-200 hover:border-cannon-600 hover:text-cannon-400">Mechaniken</a>
      <a href={`${base}de/database/`} class="rounded border border-iron-700 px-4 py-2 text-sm text-iron-200 hover:border-cannon-600 hover:text-cannon-400">Datenbank</a>
    </div>
  </section>
</BaseLayout>
