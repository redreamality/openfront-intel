---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import meta from '../../../data/_meta.json';
import maps from '../../../data/maps.json';
import units from '../../../data/units.json';
import structures from '../../../data/structures.json';

const base = import.meta.env.BASE_URL;
const sections = [
  { href: `${base}de/database/units/`, title: 'Einheiten-Datenbank', desc: `Alle ${units.length} Einheiten / Fahrzeuge / Geschosse mit Kostenformeln und Hinweisen.` },
  { href: `${base}de/database/structures/`, title: 'Gebäude-Datenbank', desc: `${structures.length} Strukturen mit Upgrades, Bauzeit und Voraussetzungen.` },
  { href: `${base}de/database/formulas/`, title: 'Formelnachschlag', desc: 'Kernformeln zu Kampf, Truppenlimit, Gold-Produktion und SAM-Reichweite.' },
  { href: `${base}de/database/maps/`, title: 'Kartenliste', desc: `${maps.meta.total} Karten in 5 Kategorien: Continental / Regional / Fantasy / Arcade / Tournament.` },
];
---

<BaseLayout title="Datenbank" description="Schnellreferenz für Einheiten, Gebäude, Karten und Formeln von OpenFront.io.">
  <PageHeader eyebrow="DATABASE" title="Datenbank" lead="Alle Werte werden aus dem Spielcode synchronisiert und eignen sich zum schnellen Nachschlagen während einer Partie." />
  <section class="container-wide py-10">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {sections.map((s) => (
        <a href={s.href} class="card group block">
          <h2 class="text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{s.title}</h2>
          <p class="mt-3 text-sm text-iron-300 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
    <p class="mt-10 text-xs text-iron-500 font-mono">Datenstand: {meta.generatedAt} · Quelle {meta.source.replace(/^.*OpenFrontIO.*/, 'OpenFrontIO ' + meta.upstreamVersion)}</p>
  </section>
</BaseLayout>
