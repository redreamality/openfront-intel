---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import UnitTable from '../../../components/UnitTable.astro';
import Callout from '../../../components/Callout.astro';
import structures from '../../../data/structures.json';
---

<BaseLayout title="Gebäude-Datenbank" description="Detaillierte Parameter zu City, Port, Factory, DefensePost, SAM und MissileSilo.">
  <PageHeader eyebrow="DATABASE / STRUCTURES" title="Gebäude-Datenbank" lead="Kosten, Bauzeit und Upgrade-Eigenschaften der 6 Strukturen. Die meisten Kosten steigen mit der Anzahl." />
  <section class="container-wide py-10 space-y-8">
    <Callout type="tip" title="Kosten-Drossel">
      <p>Die Kostenformel <code class="font-mono">min(1M, 2^n × 125k)</code> bedeutet, dass die ersten 4 City/Port/Factory 125k → 250k → 500k → 1M kosten und danach gedeckelt sind.</p>
      <p>Port und Factory <strong>teilen sich denselben Counter</strong> (PortBuildableGroup); die Reihenfolge beeinflusst gegenseitig den Preis.</p>
    </Callout>
    <UnitTable units={structures} showCategory={false} />

    <section class="rounded border border-iron-800 bg-iron-900/40 p-5 text-sm leading-relaxed">
      <h2 class="text-base font-semibold text-cannon-400">Upgrade-Stufen (4 Stufen)</h2>
      <ul class="mt-3 space-y-2 text-iron-300">
        <li><strong>City</strong> — Pro Stufe <code class="font-mono">+250,000</code> Truppenlimit; hochstufige Städte zusammen mit Factory steigern den Zug-Ertrag deutlich.</li>
        <li><strong>Port</strong> — Höhere Stufe → höhere <strong>Handelsschiff-Spawnrate und Ertragsobergrenze</strong> (v24-Ausgleich für den globalen 150er-Cap).</li>
        <li><strong>SAM Launcher</strong> — Reichweite steigt vom Standardwert 70 nahe an 150 tiles, Formel <code class="font-mono">150 − 480/(level+5)</code>.</li>
        <li><strong>Missile Silo</strong> — Upgrade verkürzt die Atomwaffen-Ladezeit; die KI meidet aktiv SAM-geschützte Ziele.</li>
        <li><strong>Factory</strong> — Erhöht Zug-Spawnrate und Schienennetz-Durchsatz.</li>
      </ul>
    </section>
  </section>
</BaseLayout>
