---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import FormulaBlock from '../../../components/FormulaBlock.astro';
import Callout from '../../../components/Callout.astro';
import formulas from '../../../data/formulas.json';

const groups = Object.entries(formulas.groups);
---

<BaseLayout title="Formelnachschlag" description="Kompakte Übersicht der Kernformeln von OpenFront.io: Kampf, Bevölkerung, Wirtschaft, Atomwaffen, Bündnisse.">
  <PageHeader eyebrow="DATABASE / FORMULAS" title="Formelnachschlag" lead="Keine Herleitungen, nur Ergebnisse. Alle Formeln finden sich in OpenFrontIO/src/core/configuration/Config.ts." />
  <section class="container-wide py-10 space-y-6">
    <Callout type="warn" title="Lesehinweis">
      <p>Die Formeln verwenden die Variablennamen aus dem Spiel (<code class="font-mono">tick</code>, <code class="font-mono">tiles</code>, <code class="font-mono">troops</code>).</p>
      <p>10 ticks ≈ 1 Sekunde. Die Konstante <code class="font-mono">DEFENSE_DEBUFF_MIDPOINT = 150,000 tiles</code> stammt aus dem Quellcode.</p>
    </Callout>
    {groups.map(([key, group]) => (
      <FormulaBlock label={group.label} items={group.items} />
    ))}
  </section>
</BaseLayout>
