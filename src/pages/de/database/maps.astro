---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import MapGrid from '../../../components/MapGrid.astro';
import maps from '../../../data/maps.json';
import { getLangFromUrl, pickI18n } from '../../../i18n';

const lang = getLangFromUrl(Astro.url);
const order = ['Continental', 'Regional', 'Fantasy', 'Arcade', 'Tournament'] as const;
const groups = order.map((key) => {
  const cat = maps.meta.categories[key];
  const catT = pickI18n(cat, lang);
  return {
    key,
    label: catT.label ?? key,
    desc: catT.desc ?? '',
    items: maps.list.filter((m) => m.category === key),
  };
});
---

<BaseLayout title="Kartenliste" description="Alle OpenFront.io-Karten in 5 Kategorien: Continental / Regional / Fantasy / Arcade / Tournament.">
  <PageHeader eyebrow="DATABASE / MAPS" title={`Kartenliste · ${maps.meta.total} Karten`} lead="Anhand des offiziellen Repository-Ordners resources/maps gescannt und nach realer Geografie und Spielmechanik gruppiert." />
  <section class="container-wide py-10">
    <nav aria-label="Kategorie-Navigation" class="mb-8 flex flex-wrap gap-2">
      {groups.map((g) => (
        <a class="rounded border border-iron-800 px-3 py-1 text-xs text-iron-300 hover:border-cannon-600 hover:text-cannon-400" href={`#cat-${g.key.toLowerCase()}`}>
          {g.label} · {g.items.length}
        </a>
      ))}
    </nav>
    <MapGrid groups={groups} />
  </section>
</BaseLayout>
