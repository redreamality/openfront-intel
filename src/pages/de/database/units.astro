---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import UnitTable from '../../../components/UnitTable.astro';
import Callout from '../../../components/Callout.astro';
import units from '../../../data/units.json';

type Unit = (typeof units)[number];
const groups: Array<{ key: Unit['category']; label: string; desc: string }> = [
  { key: 'structure', label: 'Gebäude', desc: 'Errichtbare Strukturen, einige sind aufrüstbar.' },
  { key: 'ship', label: 'Schiffe / Fahrzeuge', desc: 'See- und Landtransport- sowie Kampfeinheiten inklusive Zug und Handelsschiff.' },
  { key: 'nuke', label: 'Atomwaffen', desc: 'AtomBomb, HydrogenBomb, MIRV: Kosten und Wirkungsradius.' },
  { key: 'projectile', label: 'Munition', desc: 'Von Gebäuden/Einheiten automatisch abgefeuerte Geschosse.' },
];
---

<BaseLayout title="Einheiten-Datenbank" description="Schnellreferenz für alle 16 OpenFront.io-Einheiten / Gebäude / Fahrzeuge / Geschosse.">
  <PageHeader eyebrow="DATABASE / UNITS" title="Einheiten-Datenbank" lead="Nach Kategorie gruppiert, mit Kostenformeln, HP, Schaden und Bauzeit. Anker in den Tabellenzeilen ermöglichen Direktlinks." />
  <section class="container-wide py-10 space-y-12">
    <Callout type="spec" title="Lesekonventionen">
      <p>Die Kostenspalte zeigt oben den <strong>aktuellen Stückpreis</strong>, darunter die <strong>cost-Formel</strong> (n steht meist für die bereits gebaute Anzahl).</p>
      <p>Bauzeiten werden in <code>tick</code> angegeben; OpenFront.io läuft mit ca. <strong>10 ticks / Sekunde</strong>.</p>
      <p>Als „Upgrade" markierte Gebäude lassen sich gegen Gold aufrüsten — höhere Stufe bedeutet stärkere Effekte (z. B. SAM-Reichweite, City-Truppenlimit).</p>
    </Callout>

    {groups.map((g) => {
      const items = units.filter((u) => u.category === g.key);
      if (items.length === 0) return null;
      return (
        <section id={`group-${g.key}`}>
          <header class="mb-4 flex flex-wrap items-baseline justify-between gap-3 border-b border-iron-800 pb-2">
            <h2 class="text-xl font-semibold text-iron-50">{g.label} <span class="text-sm text-iron-500">· {items.length}</span></h2>
            <p class="text-sm text-iron-400">{g.desc}</p>
          </header>
          <UnitTable units={items} showCategory={false} />
        </section>
      );
    })}
  </section>
</BaseLayout>
