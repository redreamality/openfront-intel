---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { byLang, stripLangPrefix } from '../../../i18n';

const LANG = 'de';
const base = import.meta.env.BASE_URL;
const all = (await getCollection('strategies', ({ data }) => !data.draft))
  .filter(byLang(LANG))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = (d: Date) => new Intl.DateTimeFormat('de-DE', { dateStyle: 'medium' }).format(d);
---

<BaseLayout title="Strategien" description="FFA, Team, Naval, nukleare Abschreckungstaktiken und Rhythmusanalyse.">
  <PageHeader eyebrow="STRATEGIES" title="Strategien" lead="Praktische Artikel organisiert nach Modus und Spielstil, jeder basierend auf Quellcodewerten mit konkretem Timing und Entscheidungsbäumen." />
  <section class="container-wide py-10">
    {all.length === 0 ? (
      <p class="text-iron-400">Noch keine Artikel, bleib dran.</p>
    ) : (
      <ul class="space-y-4">
        {all.map((post) => (
          <li>
            <a href={`${base}de/strategies/${stripLangPrefix(post.slug)}/`} class="block card group">
              <div class="flex flex-wrap items-center gap-2 text-xs text-iron-500">
                <span class="tag-chip">{post.data.category ?? 'Strategie'}</span>
                {post.data.difficulty && <span class="tag-chip">Schwierigkeit · {post.data.difficulty}</span>}
                <span class="font-mono">{fmt(post.data.pubDate)}</span>
                {post.data.version && <span class="font-mono text-cannon-500">{post.data.version}</span>}
              </div>
              <h2 class="mt-2 text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{post.data.title}</h2>
              <p class="mt-2 text-sm text-iron-300 leading-relaxed">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
