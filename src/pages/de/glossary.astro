---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

interface Term {
  term: string;
  en?: string;
  desc: string;
}
const sections: Array<{ key: string; label: string; terms: Term[] }> = [
  {
    key: 'general',
    label: 'Allgemeine Begriffe',
    terms: [
      { term: 'tick', desc: 'Spielzeit-Einheit, ca. 0,1 Sekunden. 10 ticks = 1 Sekunde. Alle Cooldowns und Lebensdauern werden in ticks gemessen.' },
      { term: 'Truppen / Troops', en: 'Troops', desc: 'Vom Spieler steuerbare Bevölkerung; wird durch Angriff und Verteidigung verbraucht.' },
      { term: 'Bevölkerungslimit / MaxTroops', en: 'MaxTroops', desc: 'Obergrenze des Truppenwachstums; abhängig von tiles und City-Stufe.' },
      { term: 'Gold / Gold', en: 'Gold', desc: 'Harte Währung für Bau und Upgrades. Basisproduktion 100/tick (Human) bzw. 50/tick (Bot).' },
      { term: 'Angriffsverhältnis', en: 'Attack Ratio', desc: 'Schieberegler, der den eingesetzten Truppenanteil pro Angriff steuert.' },
      { term: 'tile', desc: 'Kleinste Karteneinheit. „tiles" steht für die Anzahl belegter Felder.' },
    ],
  },
  {
    key: 'units',
    label: 'Gebäude und Einheiten',
    terms: [
      { term: 'Stadt', en: 'City', desc: 'Pro Stufe +250.000 Truppenlimit; zugleich Bahnhof für Züge.' },
      { term: 'Hafen', en: 'Port', desc: 'Basis für Handelsschiffe, Transportschiffe und Kriegsschiffe.' },
      { term: 'Fabrik', en: 'Factory', desc: 'Produktionsquelle für Züge; arbeitet mit Schienen und Städten zusammen.' },
      { term: 'Verteidigungsposten', en: 'DefensePost', desc: 'In 30 tiles Radius mag ×5 / speed ×3.' },
      { term: 'SAM-Werfer', en: 'SAM Launcher', desc: 'Fängt AtomBomb / HydrogenBomb ab; kann MIRV nicht abfangen.' },
      { term: 'Raketensilo', en: 'Missile Silo', desc: 'Startrampe für Atomwaffen; 100 ticks Bauzeit.' },
      { term: 'Transportschiff', en: 'Transport Ship', desc: 'Landungsfahrzeug; durch Kriegsschiffe gefährdet.' },
      { term: 'Kriegsschiff', en: 'Warship', desc: 'Einheit zur Seekontrolle, HP 1000, Shell 250 Schaden.' },
      { term: 'Handelsschiff', en: 'Trade Ship', desc: 'Pendelt zwischen Häfen und erzeugt Gold; v24 globaler Cap 150.' },
      { term: 'Zug', en: 'Train', desc: 'Landgebundenes Gold-Vehikel; an Bahnhöfen verbündeter Städte 35k Gewinn.' },
      { term: 'Atombombe', en: 'Atom Bomb', desc: '750k Gold, inner 12 / outer 30.' },
      { term: 'Wasserstoffbombe', en: 'Hydrogen Bomb', desc: '5M Gold, inner 80 / outer 100.' },
      { term: 'MIRV', en: 'MIRV', desc: '25M + 15M·n; Mehrfachsprengkopf-Träger; durch SAM nicht abfangbar.' },
    ],
  },
  {
    key: 'mechanics',
    label: 'Mechanik-Begriffe',
    terms: [
      { term: 'mag', desc: 'Durchschlagskoeffizient in der Kampfformel. Gelände gibt den Basiswert, Gebäude multiplizieren.' },
      { term: 'speed', desc: 'Vorwärtsgeschwindigkeit. Wie mag durch Gelände und Gebäude beeinflusst.' },
      { term: 'Spawn-Immunität', en: 'Spawn Immunity', desc: 'Nach offiziellem Spielstart 50 ticks Angriffsimmunität.' },
      { term: 'Bündnis', en: 'Alliance', desc: '3000 ticks (5 min); Verlängerungshinweis 300 ticks vor Ablauf.' },
      { term: 'Verrat', en: 'Betrayal', desc: 'Bündnisbruch → Verteidigung ×0,5, Geschwindigkeit ×0,8, 300 ticks.' },
      { term: 'Embargo', en: 'Embargo', desc: 'Blockiert Handelsschiffe beider Seiten. Temporär (durch Angriff) oder permanent (manuell).' },
      { term: 'Fallout-Zone', en: 'Fallout', desc: 'Durch Nuke-Outer hinterlassene Strahlung; mag des Angreifers vorübergehend geschwächt.' },
      { term: 'Wassernuke-Modus', en: 'Water Nukes', desc: 'Erlaubt Nuke-Wirkung über Wasserflächen mit glattem kreisförmigem Schadensmuster.' },
      { term: 'Geländemanipulation', en: 'Terrain Manipulation', desc: 'v24 neu: Verändert die Geländekoeffizienten benachbarter tiles.' },
    ],
  },
  {
    key: 'meta',
    label: 'Spielertypen und Spielmodi',
    terms: [
      { term: 'Human', desc: 'Menschlicher Spieler, Truppenlimit ×1,0.' },
      { term: 'Nation', desc: 'Vom System benannte KI-Nation, Limit nach Schwierigkeit multipliziert.' },
      { term: 'Bot', desc: 'Basis-KI mit Nummer im Namen, Truppen ÷3.' },
      { term: 'FFA', desc: 'Free For All, 1 Spieler pro Team.' },
      { term: 'Team', desc: '2v2 bis 8v8 Teamkampf, Siegbedingung nach 5 Minuten.' },
      { term: 'Tournament', desc: 'Spezielle Turnierkarten (Tourney1–4).' },
    ],
  },
];
---

<BaseLayout title="Glossar" description="Deutsch-englisches Glossar mit kurzen Erklärungen zu OpenFront.io.">
  <PageHeader eyebrow="GLOSSARY" title="Glossar" lead="Begriffe, die dir beim Lesen der Mechaniken und Guides begegnen — hier mit deutsch-englischer Gegenüberstellung und Ein-Satz-Definition." />
  <section class="container-wide py-10 space-y-10">
    {sections.map((s) => (
      <section id={s.key}>
        <h2 class="text-xl font-semibold text-iron-50 border-b border-iron-800 pb-2 mb-4">{s.label}</h2>
        <dl class="grid gap-3 sm:grid-cols-2">
          {s.terms.map((t) => (
            <div class="rounded border border-iron-800 bg-iron-900/40 px-4 py-3">
              <dt class="flex items-baseline gap-2">
                <span class="font-semibold text-cannon-400">{t.term}</span>
                {t.en && <span class="font-mono text-xs text-iron-500">{t.en}</span>}
              </dt>
              <dd class="mt-1 text-sm text-iron-300 leading-relaxed">{t.desc}</dd>
            </div>
          ))}
        </dl>
      </section>
    ))}
  </section>
</BaseLayout>
