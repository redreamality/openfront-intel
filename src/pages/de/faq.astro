---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

const faqs = [
  {
    q: 'Was ist OpenFront.io?',
    a: 'OpenFront.io ist ein Online-Echtzeitstrategiespiel auf Basis echter Geografie und abstrakter Karten. Spieler erweitern ihr Territorium, schließen Bündnisse und starten Atomraketen auf verschiedenen Karten. Das Spiel wird von evanpelle gepflegt; der Quellcode steht unter AGPL-3.0.',
  },
  {
    q: 'Wo kann ich spielen?',
    a: 'Auf der offiziellen Seite openfront.io — direkt in allen gängigen Browsern, ohne Download oder Installation. Seit v24 wird auch nativer Mobile-Login unterstützt.',
  },
  {
    q: 'Kann ich ohne Account spielen?',
    a: 'Ja. Ein Account ist hauptsächlich dafür da, Statistiken, Skins und Bündnishistorie zu speichern. Anonyme Spieler können öffentlichen Lobbies normal beitreten.',
  },
  {
    q: 'Wo läuft die eigentliche Kampfberechnung?',
    a: 'Die Kernsimulation läuft im Browser jedes Spielers (Core ist eine deterministische TypeScript-Simulation in einem Web Worker). Der Server sammelt pro tick nur Intents und broadcastet die Turns — darum ist das Spiel sehr flüssig, hat aber gelegentlich Desync-Korrekturen.',
  },
  {
    q: 'Warum bekomme ich keine Handelsschiffe?',
    a: 'Seit v24 gilt ein globales Limit von 150 Handelsschiffen. Je mehr Schiffe unterwegs sind, desto geringer die Spawn-Wahrscheinlichkeit. Zusätzlich macht der „Embargo-Mercy-Timer" Spieler, die viel ablehnen, langsamer beim Spawnen. Lösung: Bestehende Ports upgraden statt neue bauen, und Embargos sparsam einsetzen.',
  },
  {
    q: 'Kann ich eine MIRV abfangen?',
    a: 'Nein. Sowohl die MIRV selbst als auch die abgespaltenen MIRVWarheads sind immun gegen SAM. Die sicherste Reaktion ist, City und Silo zu dezentralisieren und die City zu upgraden, um den Bevölkerungspuffer zu erhöhen.',
  },
  {
    q: 'Warum werde ich nach einem Bündnisbruch sofort angegriffen?',
    a: 'Vertragsbruch versetzt dich in den traitor-Status: Verteidigung ×0,5, Geschwindigkeit ×0,8, Dauer 30 Sekunden. Gleichzeitig wird automatisch ein Embargo gegen die ehemaligen Verbündeten ausgelöst. Wenn du in diesen 30 Sekunden keinen entscheidenden Schlag landest, schadet der Verrat meist dir selbst mehr.',
  },
  {
    q: 'Bis zu welcher Stufe kann man eine Stadt ausbauen?',
    a: 'Seit v24 unterstützen City, Port, SAM und Silo jeweils 4 Stufen. Jede Stadt-Stufe gibt +250.000 Truppenlimit, gestapelt also bis zu +1.000.000.',
  },
  {
    q: 'Kann ich die Standardeinstellungen ändern?',
    a: 'In privaten Lobbies sind einstellbar: goldMultiplier, isPeaceTime, isNukesDisabled, isSAMsDisabled, isAlliancesDisabled, isWaterNukes, spawnImmunityDuration. Öffentliche Lobbies haben modusabhängige Voreinstellungen.',
  },
  {
    q: 'Sind die Daten auf dieser Seite zuverlässig?',
    a: 'Alle Werte werden von scripts/extract-game-data.mjs aus dem OpenFrontIO-Quellcode (src/core/configuration/Config.ts, src/core/game/Game.ts, resources/maps) extrahiert. Die letzte Aktualisierungszeit und die OpenFrontIO-Versionsnummer werden im Datenbank-Footer angezeigt.',
  },
];
---

<BaseLayout title="Häufige Fragen" description="Häufige Fragen und Antworten zu OpenFront.io und dieser Seite.">
  <PageHeader eyebrow="FAQ" title="Häufige Fragen" lead="Nach Thema geordnete häufige Fragen. Detailliertere Antworten zu Spielmechaniken findest du im Bereich «Mechaniken»." />
  <section class="container-wide py-10">
    <dl class="space-y-6 max-w-3xl">
      {faqs.map((f) => (
        <div class="rounded border border-iron-800 bg-iron-900/40 px-5 py-4">
          <dt class="text-base font-semibold text-cannon-400">Q · {f.q}</dt>
          <dd class="mt-2 text-sm text-iron-300 leading-relaxed">A · {f.a}</dd>
        </div>
      ))}
    </dl>
  </section>
</BaseLayout>
