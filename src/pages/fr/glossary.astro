---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

interface Term {
  term: string;
  en?: string;
  desc: string;
}
const sections: Array<{ key: string; label: string; terms: Term[] }> = [
  {
    key: 'general',
    label: 'Termes généraux',
    terms: [
      { term: 'tick', desc: "Unité de temps du jeu, environ 0,1 seconde. 10 ticks = 1 seconde. Tous les cooldowns et durées sont comptés en ticks." },
      { term: 'Troupes', en: 'Troops', desc: "Population mobilisable par le joueur, consommée par l'attaque comme par la défense." },
      { term: 'Plafond de population', en: 'MaxTroops', desc: "Plafond de croissance des troupes, dépendant des tiles et du niveau de City." },
      { term: 'Or', en: 'Gold', desc: "Monnaie pour construire et améliorer. Production de base : 100/tick (Human) ou 50/tick (Bot)." },
      { term: "Ratio d'attaque", en: 'Attack Ratio', desc: "Curseur contrôlant le pourcentage de troupes engagées par attaque." },
      { term: 'tile', desc: "Plus petite case de la carte. Les « tiles » désignent la quantité de territoire occupé." },
    ],
  },
  {
    key: 'units',
    label: 'Bâtiments et unités',
    terms: [
      { term: 'City', en: 'City', desc: "+250 000 au plafond de troupes par niveau ; station de train." },
      { term: 'Port', en: 'Port', desc: "Base de génération des navires de commerce / transport / guerre." },
      { term: 'Factory', en: 'Factory', desc: "Source de production de trains, fonctionne avec rails et villes." },
      { term: 'DefensePost', en: 'DefensePost', desc: "Dans un rayon de 30 tiles : mag ×5 / speed ×3." },
      { term: 'Lanceur SAM', en: 'SAM Launcher', desc: "Intercepte AtomBomb / HydrogenBomb, mais pas les MIRV." },
      { term: 'Silo de missile', en: 'Missile Silo', desc: "Rampe de lancement nucléaire, 100 ticks de construction." },
      { term: 'Navire de transport', en: 'Transport Ship', desc: "Véhicule de débarquement, vulnérable aux warships." },
      { term: 'Warship', en: 'Warship', desc: "Unité de contrôle maritime, HP 1000, dégâts Shell 250." },
      { term: 'Navire de commerce', en: 'Trade Ship', desc: "Va-et-vient automatique entre Port pour produire de l'or, cap global 150 en v24." },
      { term: 'Train', en: 'Train', desc: "Véhicule terrestre porteur d'or, 35k de revenu à une station alliée." },
      { term: 'AtomBomb', en: 'Atom Bomb', desc: "750k d'or, inner 12 / outer 30." },
      { term: 'HydrogenBomb', en: 'Hydrogen Bomb', desc: "5M d'or, inner 80 / outer 100." },
      { term: 'MIRV', en: 'MIRV', desc: "25M + 15M·n, véhicule multi-ogives, non interceptable par SAM." },
    ],
  },
  {
    key: 'mechanics',
    label: 'Termes de mécaniques',
    terms: [
      { term: 'mag', desc: "Coefficient de pénétration dans le calcul d'attaque/défense. Le terrain donne la valeur de base, les bâtiments multiplient." },
      { term: 'speed', desc: "Coefficient de vitesse de progression. Influencé par le terrain et les bâtiments comme mag." },
      { term: 'Immunité de spawn', en: 'Spawn Immunity', desc: "50 ticks d'immunité après le début officiel du jeu." },
      { term: 'Alliance', en: 'Alliance', desc: "3000 ticks (5 min), invitation à renouveler 300 ticks avant expiration." },
      { term: 'Trahison', en: 'Betrayal', desc: "Rupture du pacte → défense ×0,5, vitesse ×0,8, pendant 300 ticks." },
      { term: 'Embargo', en: 'Embargo', desc: "Empêche les navires de commerce entre deux joueurs. Temporaire (déclenché par attaque) ou permanent (manuel)." },
      { term: 'Retombées', en: 'Fallout', desc: "Zone de radiation laissée par l'outer d'une explosion nucléaire ; affaiblit temporairement le mag de l'attaquant." },
      { term: 'Mode water nukes', en: 'Water Nukes', desc: "Permet aux explosions nucléaires de couvrir la mer, avec dégâts en cercle régulier." },
      { term: 'Manipulation du terrain', en: 'Terrain Manipulation', desc: "Nouveauté v24 : modifie le coefficient de terrain des tiles adjacents." },
    ],
  },
  {
    key: 'meta',
    label: 'Joueurs et types de partie',
    terms: [
      { term: 'Human', desc: "Joueur humain, plafond de troupes ×1,0." },
      { term: 'Nation', desc: "IA nommée par le système, plafond multiplié selon la difficulté." },
      { term: 'Bot', desc: "IA basique, nom avec chiffres, troupes ÷3." },
      { term: 'FFA', desc: "Free For All, 1 joueur par équipe." },
      { term: 'Team', desc: "Équipes 2v2 à 8v8, condition de victoire à 5 minutes." },
      { term: 'Tournament', desc: "Cartes dédiées aux tournois (Tourney1 à 4)." },
    ],
  },
];
---

<BaseLayout title="Glossaire" description="Glossaire français-anglais d'OpenFront.io avec définitions concises.">
  <PageHeader eyebrow="GLOSSARY" title="Glossaire" lead="Pour tous les concepts inconnus rencontrés dans les guides et mécaniques : correspondance français-anglais et définition en une phrase." />
  <section class="container-wide py-10 space-y-10">
    {sections.map((s) => (
      <section id={s.key}>
        <h2 class="text-xl font-semibold text-iron-50 border-b border-iron-800 pb-2 mb-4">{s.label}</h2>
        <dl class="grid gap-3 sm:grid-cols-2">
          {s.terms.map((t) => (
            <div class="rounded border border-iron-800 bg-iron-900/40 px-4 py-3">
              <dt class="flex items-baseline gap-2">
                <span class="font-semibold text-cannon-400">{t.term}</span>
                {t.en && <span class="font-mono text-xs text-iron-500">{t.en}</span>}
              </dt>
              <dd class="mt-1 text-sm text-iron-300 leading-relaxed">{t.desc}</dd>
            </div>
          ))}
        </dl>
      </section>
    ))}
  </section>
</BaseLayout>
