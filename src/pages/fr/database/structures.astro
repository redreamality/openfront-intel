---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import UnitTable from '../../../components/UnitTable.astro';
import Callout from '../../../components/Callout.astro';
import structures from '../../../data/structures.json';
---

<BaseLayout title="Base de données des bâtiments" description="Paramètres détaillés des City, Port, Factory, DefensePost, SAM et MissileSilo.">
  <PageHeader eyebrow="DATABASE / STRUCTURES" title="Base de données des bâtiments" lead="Coût, temps de construction et caractéristiques d'amélioration des 6 structures. La plupart des bâtiments voient leur coût augmenter avec la quantité." />
  <section class="container-wide py-10 space-y-8">
    <Callout type="tip" title="Économie sur les coûts de construction">
      <p>La formule de coût <code class="font-mono">min(1M, 2^n × 125k)</code> implique que les 4 premières City/Port/Factory coûtent respectivement 125k → 250k → 500k → 1M, puis plafonnent.</p>
      <p>Port et Factory <strong>partagent un même compteur</strong> (PortBuildableGroup), donc leur ordre d'achat influe sur leurs prix mutuels.</p>
    </Callout>
    <UnitTable units={structures} showCategory={false} />

    <section class="rounded border border-iron-800 bg-iron-900/40 p-5 text-sm leading-relaxed">
      <h2 class="text-base font-semibold text-cannon-400">Échelle d'amélioration (4 niveaux)</h2>
      <ul class="mt-3 space-y-2 text-iron-300">
        <li><strong>City</strong> — <code class="font-mono">+250 000</code> au plafond de troupes par niveau ; les City de haut niveau associées à des Factory augmentent significativement le revenu des trains.</li>
        <li><strong>Port</strong> — plus le niveau est élevé, plus la <strong>fréquence de spawn et le revenu plafond des navires de commerce</strong> sont élevés (compensation v24 du cap global de 150).</li>
        <li><strong>SAM Launcher</strong> — portée passant de 70 par défaut à près de 150 tiles, formule <code class="font-mono">150 − 480/(level+5)</code>.</li>
        <li><strong>Missile Silo</strong> — l'amélioration réduit le temps de rechargement nucléaire ; l'IA évite les cibles couvertes par SAM.</li>
        <li><strong>Factory</strong> — augmente la cadence de génération des trains et le débit du réseau ferré.</li>
      </ul>
    </section>
  </section>
</BaseLayout>
