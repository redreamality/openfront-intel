---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import FormulaBlock from '../../../components/FormulaBlock.astro';
import Callout from '../../../components/Callout.astro';
import formulas from '../../../data/formulas.json';

const groups = Object.entries(formulas.groups);
---

<BaseLayout title="Formules rapides" description="Référence rapide des formules cœur d'OpenFront.io : attaque/défense, population, économie, nucléaire, alliance.">
  <PageHeader eyebrow="DATABASE / FORMULAS" title="Formules rapides" lead="Sans dérivation, juste les conclusions. Toutes les formules correspondent à des implémentations trouvables dans OpenFrontIO/src/core/configuration/Config.ts." />
  <section class="container-wide py-10 space-y-6">
    <Callout type="warn" title="Notes de lecture">
      <p>Les formules utilisent les noms de variables internes du jeu (<code class="font-mono">tick</code>, <code class="font-mono">tiles</code>, <code class="font-mono">troops</code>).</p>
      <p>10 ticks ≈ 1 seconde. La constante <code class="font-mono">DEFENSE_DEBUFF_MIDPOINT = 150,000 tiles</code> provient des constantes du code source.</p>
    </Callout>
    {groups.map(([key, group]) => (
      <FormulaBlock label={group} items={group.items} />
    ))}
  </section>
</BaseLayout>
