---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import meta from '../../../data/_meta.json';
import maps from '../../../data/maps.json';
import units from '../../../data/units.json';
import structures from '../../../data/structures.json';

const base = import.meta.env.BASE_URL;
const sections = [
  { href: `${base}fr/database/units/`, title: 'Base de données des unités', desc: `${units.length} unités / véhicules / munitions, avec formules de coût et notes.` },
  { href: `${base}fr/database/structures/`, title: 'Base de données des bâtiments', desc: `${structures.length} structures, avec améliorations, temps de construction et conditions de déblocage.` },
  { href: `${base}fr/database/formulas/`, title: 'Formules rapides', desc: "Formules clés d'attaque/défense, plafond de troupes, production d'or et portée SAM." },
  { href: `${base}fr/database/maps/`, title: 'Liste des cartes', desc: `${maps.meta.total} cartes groupées par catégorie : continentale / régionale / fantasy / arcade / tournoi.` },
];
---

<BaseLayout title="Base de données" description="Tableaux de référence rapide pour les unités, bâtiments, cartes et formules d'OpenFront.io.">
  <PageHeader eyebrow="DATABASE" title="Base de données" lead="Toutes les valeurs sont synchronisées depuis le code source du jeu, à utiliser comme référence rapide en cours de partie." />
  <section class="container-wide py-10">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {sections.map((s) => (
        <a href={s.href} class="card group block">
          <h2 class="text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{s.title}</h2>
          <p class="mt-3 text-sm text-iron-300 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
    <p class="mt-10 text-xs text-iron-500 font-mono">Données mises à jour : {meta.generatedAt} · Source {meta.source.replace(/^.*OpenFrontIO.*/, 'OpenFrontIO ' + meta.upstreamVersion)}</p>
  </section>
</BaseLayout>
