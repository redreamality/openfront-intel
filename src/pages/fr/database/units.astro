---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import UnitTable from '../../../components/UnitTable.astro';
import Callout from '../../../components/Callout.astro';
import units from '../../../data/units.json';

type Unit = (typeof units)[number];
const groups: Array<{ key: Unit['category']; label: string; desc: string }> = [
  { key: 'structure', label: 'Bâtiments', desc: "Structures constructibles, certaines améliorables pour renforcer leurs propriétés." },
  { key: 'ship', label: 'Navires / véhicules', desc: "Unités de transport et de combat maritimes et terrestres, dont trains et navires de commerce." },
  { key: 'nuke', label: 'Armes nucléaires', desc: "AtomBomb, HydrogenBomb, MIRV : coûts et rayons d'impact." },
  { key: 'projectile', label: 'Munitions', desc: "Projectiles tirés automatiquement par les bâtiments / unités." },
];
---

<BaseLayout title="Base de données des unités" description="Référence rapide des 16 unités / bâtiments / véhicules / munitions d'OpenFront.io.">
  <PageHeader eyebrow="DATABASE / UNITS" title="Base de données des unités" lead="Groupées par catégorie, avec formule de coût, HP, dégâts et temps de construction. Les ancres dans les lignes du tableau permettent de partager des liens directs." />
  <section class="container-wide py-10 space-y-12">
    <Callout type="spec" title="Conventions de lecture">
      <p>Dans la colonne coût, le haut indique le <strong>prix unitaire actuel</strong>, le bas la <strong>formule de coût</strong> (n représente généralement le nombre déjà construit).</p>
      <p>Le temps de construction est exprimé en <code>tick</code>, OpenFront.io tourne à environ <strong>10 ticks / seconde</strong>.</p>
      <p>Les bâtiments marqués « améliorable » peuvent monter en niveau via de l'or, avec des effets croissants (portée SAM, plafond de troupes City, etc.).</p>
    </Callout>

    {groups.map((g) => {
      const items = units.filter((u) => u.category === g.key);
      if (items.length === 0) return null;
      return (
        <section id={`group-${g.key}`}>
          <header class="mb-4 flex flex-wrap items-baseline justify-between gap-3 border-b border-iron-800 pb-2">
            <h2 class="text-xl font-semibold text-iron-50">{g.label} <span class="text-sm text-iron-500">· {items.length}</span></h2>
            <p class="text-sm text-iron-400">{g.desc}</p>
          </header>
          <UnitTable units={items} showCategory={false} />
        </section>
      );
    })}
  </section>
</BaseLayout>
