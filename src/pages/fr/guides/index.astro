---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { byLang, stripLangPrefix } from '../../../i18n';

const LANG = 'fr';
const base = import.meta.env.BASE_URL;
const all = (await getCollection('guides', ({ data }) => !data.draft))
  .filter(byLang(LANG))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = (d: Date) => new Intl.DateTimeFormat('fr-FR', { dateStyle: 'medium' }).format(d);
---

<BaseLayout title="Tutoriels" description="Tutoriels OpenFront.io du débutant à l'avancé, panneau de commande, raccourcis clavier et analyse de la première partie.">
  <PageHeader eyebrow="GUIDES" title="Tutoriels" lead="De l'ouverture du jeu à votre première expansion réussie, étape par étape." />
  <section class="container-wide py-10">
    {all.length === 0 ? (
      <p class="text-iron-400">Aucun tutoriel pour le moment.</p>
    ) : (
      <ul class="space-y-4">
        {all.map((post) => (
          <li>
            <a href={`${base}fr/guides/${stripLangPrefix(post.slug)}/`} class="block card group">
              <div class="flex flex-wrap items-center gap-2 text-xs text-iron-500">
                <span class="tag-chip">{post.data.category ?? 'Tutoriel'}</span>
                {post.data.difficulty && <span class="tag-chip">Difficulté · {post.data.difficulty}</span>}
                <span class="font-mono">{fmt(post.data.pubDate)}</span>
              </div>
              <h2 class="mt-2 text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{post.data.title}</h2>
              <p class="mt-2 text-sm text-iron-300 leading-relaxed">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
