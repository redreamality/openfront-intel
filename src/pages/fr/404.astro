---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404 · Page introuvable" description="La page que vous cherchez n'existe pas." noindex={true}>
  <section class="container-wide py-24 text-center">
    <p class="font-mono text-xs uppercase tracking-widest text-iron-500">ERROR · 404</p>
    <h1 class="mt-3 text-5xl font-bold text-cannon-500">Territoire perdu</h1>
    <p class="mt-4 text-iron-300 max-w-md mx-auto leading-relaxed">La page que vous cherchez n'existe pas ou a été conquise. Essayez de vous réorganiser via les entrées ci-dessous :</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href={`${base}fr/`} class="rounded bg-cannon-600 px-4 py-2 text-sm text-iron-950 hover:bg-cannon-500">Retour à l'accueil</a>
      <a href={`${base}fr/mechanics/`} class="rounded border border-iron-700 px-4 py-2 text-sm text-iron-200 hover:border-cannon-600 hover:text-cannon-400">Parcourir les mécaniques</a>
      <a href={`${base}fr/database/`} class="rounded border border-iron-700 px-4 py-2 text-sm text-iron-200 hover:border-cannon-600 hover:text-cannon-400">Consulter la base de données</a>
    </div>
  </section>
</BaseLayout>
