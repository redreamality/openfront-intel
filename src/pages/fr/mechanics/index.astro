---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';

const base = import.meta.env.BASE_URL;
const langPrefix = 'fr/';
const sections = [
  { href: `${base}${langPrefix}mechanics/basics/`, title: 'Les bases : Spawn et Expansion', desc: "Immunité de spawn, durée des phases, cadre de décision initial.", tag: 'Initiation' },
  { href: `${base}${langPrefix}mechanics/economy/`, title: 'Économie : or, commerce et population', desc: "Or de base, troupes de City, navires de commerce, revenus des trains.", tag: 'Économie' },
  { href: `${base}${langPrefix}mechanics/military/`, title: 'Militaire : attaque, défense et combat', desc: "Coefficients de terrain, postes de défense, malus de population, pénalité de trahison.", tag: 'Combat' },
  { href: `${base}${langPrefix}mechanics/structures/`, title: 'Bâtiments : les 6 structures clés', desc: 'City / Port / Factory / DefensePost / SAM / Silo.', tag: 'Bâtiments' },
  { href: `${base}${langPrefix}mechanics/units/`, title: 'Unités : navires, trains et munitions', desc: "Navires de transport, warships, navires de commerce, trains, obus / missiles SAM.", tag: 'Unités' },
  { href: `${base}${langPrefix}mechanics/nukes/`, title: 'Armes nucléaires et SAM', desc: 'AtomBomb / HydrogenBomb / MIRV et le bouclier SAM.', tag: 'Guerre nucléaire' },
  { href: `${base}${langPrefix}mechanics/alliances/`, title: 'Alliances et trahisons', desc: "Alliance de 5 min, embargo automatique, malus de trahison 0,5 × 0,8.", tag: 'Diplomatie' },
  { href: `${base}${langPrefix}mechanics/trains/`, title: 'Trains et rails', desc: "Nouvelle mécanique v24 : Factory → Train → réseau commercial de City.", tag: 'Nouveauté' },
  { href: `${base}${langPrefix}mechanics/trade/`, title: 'Système commercial', desc: "Cap 150 navires, revenus par distance, timer de pitié pour refus de commerce.", tag: 'Économie' },
  { href: `${base}${langPrefix}mechanics/modes/`, title: 'Aperçu des modes de jeu', desc: 'FFA / Duos / Trios / Quads / Team / Tournament.', tag: 'Vue d\'ensemble' },
];
---

<BaseLayout title="Mécaniques du jeu" description="Toutes les mécaniques de base d'OpenFront.io : du spawn à la guerre nucléaire, 10 thèmes expliqués systématiquement.">
  <PageHeader eyebrow="MÉCANIQUES" title="Mécaniques du jeu" lead="10 chapitres organisés par système, dont chaque valeur numérique provient du code source v24. Conseil : commencez par « Les bases » et « Économie »." />
  <section class="container-wide py-10">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sections.map((s, i) => (
        <a href={s.href} class="card group block">
          <div class="flex items-center justify-between text-xs">
            <span class="font-mono text-iron-500">{String(i + 1).padStart(2, '0')}</span>
            <span class="tag-chip">{s.tag}</span>
          </div>
          <h2 class="mt-3 text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{s.title}</h2>
          <p class="mt-2 text-sm text-iron-300 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
