---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404 · Page Not Found" description="The page you're looking for doesn't exist." noindex={true}>
  <section class="container-wide py-24 text-center">
    <p class="font-mono text-xs uppercase tracking-widest text-iron-500">ERROR · 404</p>
    <h1 class="mt-3 text-5xl font-bold text-cannon-500">Territory Lost</h1>
    <p class="mt-4 text-iron-300 max-w-md mx-auto leading-relaxed">The page you're looking for doesn't exist or has been captured. Try these entry points to regroup:</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href={base} class="rounded bg-cannon-600 px-4 py-2 text-sm text-iron-950 hover:bg-cannon-500">Back to Home</a>
      <a href={`${base}mechanics/`} class="rounded border border-iron-700 px-4 py-2 text-sm text-iron-200 hover:border-cannon-600 hover:text-cannon-400">Browse Mechanics</a>
      <a href={`${base}database/`} class="rounded border border-iron-700 px-4 py-2 text-sm text-iron-200 hover:border-cannon-600 hover:text-cannon-400">View Database</a>
    </div>
  </section>
</BaseLayout>
