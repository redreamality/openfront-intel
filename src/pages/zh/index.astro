---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n';

const lang = 'zh';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const langPrefix = `${lang}/`;

const pillars = [
  {
    href: `${base}${langPrefix}mechanics/`,
    title: t('home.pillar.mechanics.title'),
    desc: t('home.pillar.mechanics.desc'),
    accent: 'cannon',
  },
  {
    href: `${base}${langPrefix}database/`,
    title: t('home.pillar.database.title'),
    desc: t('home.pillar.database.desc'),
    accent: 'military',
  },
  {
    href: `${base}${langPrefix}strategies/`,
    title: t('home.pillar.strategies.title'),
    desc: t('home.pillar.strategies.desc'),
    accent: 'cannon',
  },
  {
    href: `${base}${langPrefix}guides/`,
    title: t('home.pillar.guides.title'),
    desc: t('home.pillar.guides.desc'),
    accent: 'military',
  },
];

const highlights = [
  { label: t('stats.atomBomb'), value: '750,000 G' },
  { label: t('stats.hydrogenBomb'), value: '5,000,000 G' },
  { label: t('stats.mirv'), value: '25M + 15M·n' },
  { label: t('stats.samRange'), value: '70 → 150 tiles' },
  { label: t('stats.allianceDuration'), value: '3000 ticks ≈ 5 分钟' },
  { label: t('stats.betrayalPenalty'), value: '×0.5 持续 300 ticks' },
  { label: t('stats.cityBonus'), value: '+250,000 / 级' },
  { label: t('stats.tradeShipCap'), value: '150 (v24)' },
];
---

<BaseLayout title={t('site.title')} description={t('site.description')}>
  <section class="relative overflow-hidden border-b border-iron-800">
    <div class="container-wide py-20 sm:py-28">
      <p class="tag-chip">{t('site.tagline')}</p>
      <h1 class="mt-4 max-w-3xl text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-iron-50">
        <span class="text-cannon-500">OpenFront</span> {t('home.hero.title')}
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-iron-300 leading-relaxed">
        围绕开源实时策略游戏 <a class="text-cannon-400 hover:underline" href="https://openfront.io/" target="_blank" rel="noopener">OpenFront.io</a> 整理的中文机制百科：从出生免疫到 MIRV 弹道，每条规则都有来源、数字与公式。
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={`${base}${langPrefix}mechanics/`} class="rounded bg-cannon-600 px-4 py-2 text-sm font-semibold text-iron-950 hover:bg-cannon-500">{t('home.cta.mechanics')}</a>
        <a href={`${base}${langPrefix}database/`} class="rounded border border-iron-700 px-4 py-2 text-sm text-iron-200 hover:border-cannon-600 hover:text-cannon-400">{t('home.cta.database')}</a>
        <a href={`${base}${langPrefix}strategies/`} class="rounded border border-iron-700 px-4 py-2 text-sm text-iron-200 hover:border-military-500 hover:text-military-300">{t('home.cta.strategies')}</a>
      </div>
    </div>
  </section>

  <section class="container-wide py-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {pillars.map((p) => (
        <a href={p.href} class="card group block">
          <div class="text-xs uppercase tracking-widest text-iron-500">{t('home.section')}</div>
          <div class:list={["mt-1 text-lg font-semibold", p.accent === 'cannon' ? 'text-cannon-400' : 'text-military-300']}>{p.title}</div>
          <p class="mt-3 text-sm text-iron-300 leading-relaxed">{p.desc}</p>
          <div class="mt-4 text-xs text-iron-500 group-hover:text-cannon-400">{t('home.goto')} →</div>
        </a>
      ))}
    </div>
  </section>

  <section class="container-wide pb-20">
    <h2 class="text-xl font-semibold text-iron-50">{t('home.highlights')}</h2>
    <p class="mt-1 text-sm text-iron-400">{t('home.highlights.source')} <code class="font-mono text-cannon-400">scripts/extract-game-data.mjs</code></p>
    <ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {highlights.map((h) => (
        <li class="flex items-center justify-between rounded border border-iron-800 bg-iron-900/40 px-4 py-3">
          <span class="text-sm text-iron-300">{h.label}</span>
          <span class="font-mono text-sm text-cannon-400">{h.value}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
