---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import meta from '../../../data/_meta.json';
import maps from '../../../data/maps.json';
import units from '../../../data/units.json';
import structures from '../../../data/structures.json';

const base = import.meta.env.BASE_URL;
const sections = [
  { href: `${base}database/units/`, title: '单位数据库', desc: `全部 ${units.length} 种单位 / 载具 / 弹药，含成本公式与备注。` },
  { href: `${base}database/structures/`, title: '建筑数据库', desc: `${structures.length} 种结构，含可升级、建造时长、解锁条件。` },
  { href: `${base}database/formulas/`, title: '公式速查', desc: '攻防、部队上限、金币产出、SAM 射程的核心公式。' },
  { href: `${base}database/maps/`, title: '地图列表', desc: `${maps.meta.total} 张地图按类别分组：大陆 / 区域 / 幻想 / 街机 / 锦标赛。` },
];
---

<BaseLayout title="数据库" description="OpenFront.io 单位、建筑、地图与公式速查表。">
  <PageHeader eyebrow="DATABASE" title="数据库" lead="所有数值都从游戏源码同步，可作为对局中临时查阅的随手资料。" />
  <section class="container-wide py-10">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {sections.map((s) => (
        <a href={s.href} class="card group block">
          <h2 class="text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{s.title}</h2>
          <p class="mt-3 text-sm text-iron-300 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
    <p class="mt-10 text-xs text-iron-500 font-mono">数据更新：{meta.generatedAt} · 来源 {meta.source.replace(/^.*OpenFrontIO.*/, 'OpenFrontIO ' + meta.upstreamVersion)}</p>
  </section>
</BaseLayout>
