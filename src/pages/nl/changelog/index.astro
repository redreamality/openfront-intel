---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { byLang, stripLangPrefix } from '../../../i18n';

const LANG = 'nl';
const base = import.meta.env.BASE_URL;
const entries = (await getCollection('changelog'))
  .filter(byLang(LANG))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = (d: Date) => new Intl.DateTimeFormat('nl-NL', { dateStyle: 'medium' }).format(d);
---

<BaseLayout title="Wijzigingslog" description="OpenFront.io versie-updates en balanswijzigingen per versie.">
  <PageHeader eyebrow="CHANGELOG" title="Wijzigingslog" lead="Per versie georganiseerd, met de nadruk op balanswijzigingen die gameplay-beslissingen beïnvloeden." />
  <section class="container-wide py-10">
    <ul class="space-y-4">
      {entries.map((post) => (
        <li>
          <a href={`${base}nl/changelog/${stripLangPrefix(post.slug)}/`} class="block card group">
            <div class="flex flex-wrap items-center gap-2 text-xs text-iron-500">
              <span class="tag-chip">{post.data.version}</span>
              <span class="font-mono">{fmt(post.data.pubDate)}</span>
            </div>
            <h2 class="mt-2 text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{post.data.title}</h2>
            <p class="mt-2 text-sm text-iron-300 leading-relaxed">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
