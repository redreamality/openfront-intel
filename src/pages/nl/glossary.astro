---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

interface Term {
  term: string;
  en?: string;
  desc: string;
}
const sections: Array<{ key: string; label: string; terms: Term[] }> = [
  {
    key: 'general',
    label: 'Algemene termen',
    terms: [
      { term: 'tick', desc: 'Tijdseenheid in het spel, ongeveer 0,1 seconde. 10 tick = 1 seconde. Alle cooldowns en levensduren worden in tick uitgedrukt.' },
      { term: 'Troepen / Troops', en: 'Troops', desc: 'De bevolking die de speler kan inzetten; wordt verbruikt bij zowel aanval als verdediging.' },
      { term: 'Bevolkingslimiet / MaxTroops', en: 'MaxTroops', desc: 'Het plafond voor de groei van Troops, afhankelijk van tiles en City-niveau.' },
      { term: 'Goud / Gold', en: 'Gold', desc: 'De universele valuta voor bouwen en upgraden. Basisproductie 100/tick (Human) of 50/tick (Bot).' },
      { term: 'Aanvalsratio', en: 'Attack Ratio', desc: 'Schuifregelaar die het aandeel ingezette troepen per aanval bepaalt.' },
      { term: 'tile', desc: 'De kleinste eenheid op de kaart. Het aantal tiles is het aantal bezette vakjes.' },
    ],
  },
  {
    key: 'units',
    label: 'Gebouwen en eenheden',
    terms: [
      { term: 'Stad', en: 'City', desc: '+250.000 troops-limiet per niveau; tevens treinstation.' },
      { term: 'Haven', en: 'Port', desc: 'Basis voor handelsschepen / transportschepen / oorlogsschepen.' },
      { term: 'Fabriek', en: 'Factory', desc: 'Productiebron voor treinen, werkt samen met spoor en steden.' },
      { term: 'Verdedigingspost', en: 'DefensePost', desc: 'Binnen 30 tiles: mag ×5 / speed ×3.' },
      { term: 'SAM-lanceerder', en: 'SAM Launcher', desc: 'Onderschept AtomBomb en HydrogenBomb, kan geen MIRV onderscheppen.' },
      { term: 'Raketsilo', en: 'Missile Silo', desc: 'Lanceerplatform voor kernwapens, bouwduur 100 ticks.' },
      { term: 'Transportschip', en: 'Transport Ship', desc: 'Landingsvaartuig, kwetsbaar voor warships.' },
      { term: 'Oorlogsschip', en: 'Warship', desc: 'Eenheid voor zeebeheersing, HP 1000, Shell 250 schade.' },
      { term: 'Handelsschip', en: 'Trade Ship', desc: 'Pendelt automatisch tussen havens en produceert goud. Globale cap 150 sinds v24.' },
      { term: 'Trein', en: 'Train', desc: 'Goudvoertuig op het land; oplevering 35k bij bondgenootstations.' },
      { term: 'AtomBomb', en: 'Atom Bomb', desc: '750k goud, inner 12 / outer 30.' },
      { term: 'HydrogenBomb', en: 'Hydrogen Bomb', desc: '5M goud, inner 80 / outer 100.' },
      { term: 'MIRV', en: 'MIRV', desc: '25M + 15M·n, voertuig met meerdere kernkoppen, niet te onderscheppen door SAM.' },
    ],
  },
  {
    key: 'mechanics',
    label: 'Mechaniektermen',
    terms: [
      { term: 'mag', desc: 'De pantserdoorbrekingsfactor in de gevechtsformule. Het terrein bepaalt de basiswaarde, gebouwen vermenigvuldigen.' },
      { term: 'speed', desc: 'De voortgangsfactor. Net als mag beïnvloed door terrein en gebouwen.' },
      { term: 'Spawn-immuniteit', en: 'Spawn Immunity', desc: 'Aanvalsimmuniteit gedurende 50 ticks na het officiële begin van de slag.' },
      { term: 'Alliantie', en: 'Alliance', desc: '3000 ticks (5 min); 300 ticks voor het einde verschijnt een hernieuwingsoptie.' },
      { term: 'Verraad', en: 'Betrayal', desc: 'Verbond verbreken → verdediging ×0,5, snelheid ×0,8, gedurende 300 ticks.' },
      { term: 'Embargo', en: 'Embargo', desc: 'Blokkeert handelsschepen tussen twee partijen. Tijdelijk (na aanval) of permanent (handmatig).' },
      { term: 'Fallout-zone', en: 'Fallout', desc: 'Straling in het outer-gebied van een kernexplosie; verzwakt tijdelijk de mag van de aanvaller.' },
      { term: 'Watercore-modus', en: 'Water Nukes', desc: 'Staat kernexplosies toe over zee; gebruikt een gladde cirkelvormige schade.' },
      { term: 'Terreinmanipulatie', en: 'Terrain Manipulation', desc: 'Nieuw in v24: beïnvloedt de terreincoëfficiënt van aangrenzende tiles.' },
    ],
  },
  {
    key: 'meta',
    label: 'Spelers en speltypes',
    terms: [
      { term: 'Human', desc: 'Echte speler; troops-limiet ×1,0.' },
      { term: 'Nation', desc: 'AI-natie met systeemnaam; limiet vermenigvuldigd met moeilijkheidsgraad.' },
      { term: 'Bot', desc: 'Basis-AI met cijfer in de naam; troops ÷3.' },
      { term: 'FFA', desc: 'Free For All; één speler per team.' },
      { term: 'Team', desc: '2v2 tot 8v8 teamgevecht; overwinningsvoorwaarde na 5 minuten.' },
      { term: 'Tournament', desc: 'Toernooi-specifieke kaarten (Tourney1~4).' },
    ],
  },
];
---

<BaseLayout title="Woordenlijst" description="Overzicht van OpenFront.io-termen in het Engels en het Nederlands met korte uitleg.">
  <PageHeader eyebrow="GLOSSARY" title="Woordenlijst" lead="Onbekende termen in de mechanieken of gidsen vind je hier met een Engels-Nederlandse vertaling en een korte definitie." />
  <section class="container-wide py-10 space-y-10">
    {sections.map((s) => (
      <section id={s.key}>
        <h2 class="text-xl font-semibold text-iron-50 border-b border-iron-800 pb-2 mb-4">{s.label}</h2>
        <dl class="grid gap-3 sm:grid-cols-2">
          {s.terms.map((t) => (
            <div class="rounded border border-iron-800 bg-iron-900/40 px-4 py-3">
              <dt class="flex items-baseline gap-2">
                <span class="font-semibold text-cannon-400">{t.term}</span>
                {t.en && <span class="font-mono text-xs text-iron-500">{t.en}</span>}
              </dt>
              <dd class="mt-1 text-sm text-iron-300 leading-relaxed">{t.desc}</dd>
            </div>
          ))}
        </dl>
      </section>
    ))}
  </section>
</BaseLayout>
