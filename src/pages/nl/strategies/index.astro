---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { byLang, stripLangPrefix } from '../../../i18n';

const LANG = 'nl';
const base = import.meta.env.BASE_URL;
const all = (await getCollection('strategies', ({ data }) => !data.draft))
  .filter(byLang(LANG))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = (d: Date) => new Intl.DateTimeFormat('nl-NL', { dateStyle: 'medium' }).format(d);
---

<BaseLayout title="Strategieën" description="FFA, Team, Naval, nucleaire afschrikkingstactieken en ritmeanalyse.">
  <PageHeader eyebrow="STRATEGIES" title="Strategieën" lead="Praktische artikelen georganiseerd per modus en speelstijl, elk gebaseerd op broncodewaarden met specifieke timing en beslissingsbomen." />
  <section class="container-wide py-10">
    {all.length === 0 ? (
      <p class="text-iron-400">Nog geen artikelen, blijf op de hoogte.</p>
    ) : (
      <ul class="space-y-4">
        {all.map((post) => (
          <li>
            <a href={`${base}nl/strategies/${stripLangPrefix(post.slug)}/`} class="block card group">
              <div class="flex flex-wrap items-center gap-2 text-xs text-iron-500">
                <span class="tag-chip">{post.data.category ?? 'Strategie'}</span>
                {post.data.difficulty && <span class="tag-chip">Moeilijkheid · {post.data.difficulty}</span>}
                <span class="font-mono">{fmt(post.data.pubDate)}</span>
                {post.data.version && <span class="font-mono text-cannon-500">{post.data.version}</span>}
              </div>
              <h2 class="mt-2 text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{post.data.title}</h2>
              <p class="mt-2 text-sm text-iron-300 leading-relaxed">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
