---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';

const base = import.meta.env.BASE_URL;
const langPrefix = 'nl/';
const sections = [
  { href: `${base}${langPrefix}mechanics/basics/`, title: 'Basis: spawn en expansie', desc: 'Spawn-immuniteit, faseduur, beslissingskader voor de opening.', tag: 'Basis' },
  { href: `${base}${langPrefix}mechanics/economy/`, title: 'Economie: goud, handel en bevolking', desc: 'Basisgoud, stadsbevolking, handelsschepen, treinopbrengsten.', tag: 'Economie' },
  { href: `${base}${langPrefix}mechanics/military/`, title: 'Militair: aanval en verdediging', desc: 'Terreincoëfficiënten, DefensePost, grote-legerstraf, verraadboete.', tag: 'Gevecht' },
  { href: `${base}${langPrefix}mechanics/structures/`, title: 'Gebouwen: 6 kernstructuren', desc: 'City / Port / Factory / DefensePost / SAM / Silo.', tag: 'Bouw' },
  { href: `${base}${langPrefix}mechanics/units/`, title: 'Eenheden: schepen, voertuigen en projectielen', desc: 'Transportschip, warship, handelsschip, trein, shells / SAM-raketten.', tag: 'Eenheden' },
  { href: `${base}${langPrefix}mechanics/nukes/`, title: 'Kernwapens en SAM', desc: 'AtomBomb / HydrogenBomb / MIRV en het SAM-onderscheppingsnet.', tag: 'Kernwapens' },
  { href: `${base}${langPrefix}mechanics/alliances/`, title: 'Allianties en verraad', desc: 'Alliantie van 5 min, automatisch embargo, verraadstraf 0,5×0,8.', tag: 'Diplomatie' },
  { href: `${base}${langPrefix}mechanics/trains/`, title: 'Treinen en spoor', desc: 'Nieuw in v24: factory → trein → handelsnet tussen steden.', tag: 'Nieuw' },
  { href: `${base}${langPrefix}mechanics/trade/`, title: 'Handelssysteem', desc: 'Cap van 150 handelsschepen, opbrengstcurve op afstand, mercy-timer voor weigering.', tag: 'Economie' },
  { href: `${base}${langPrefix}mechanics/modes/`, title: 'Overzicht van speltypes', desc: 'FFA / Duos / Trios / Quads / Team / Tournament.', tag: 'Overzicht' },
];
---

<BaseLayout title="Spelmechanieken" description="Alle kernmechanieken van OpenFront.io: 10 systematisch uitgelegde thema's van spawn tot kernoorlog.">
  <PageHeader eyebrow="MECHANIEK" title="Spelmechanieken" lead="10 hoofdstukken, opgedeeld per systeem; alle cijfers komen uit de v24-broncode. Begin bij voorkeur bij 'Basis' en 'Economie'." />
  <section class="container-wide py-10">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sections.map((s, i) => (
        <a href={s.href} class="card group block">
          <div class="flex items-center justify-between text-xs">
            <span class="font-mono text-iron-500">{String(i + 1).padStart(2, '0')}</span>
            <span class="tag-chip">{s.tag}</span>
          </div>
          <h2 class="mt-3 text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{s.title}</h2>
          <p class="mt-2 text-sm text-iron-300 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
