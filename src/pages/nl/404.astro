---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404 · Pagina niet gevonden" description="De pagina die u zoekt bestaat niet." noindex={true}>
  <section class="container-wide py-24 text-center">
    <p class="font-mono text-xs uppercase tracking-widest text-iron-500">ERROR · 404</p>
    <h1 class="mt-3 text-5xl font-bold text-cannon-500">Territorium verloren</h1>
    <p class="mt-4 text-iron-300 max-w-md mx-auto leading-relaxed">De pagina die u bezoekt bestaat niet of is veroverd. Probeer u te hergroeperen via een van onderstaande ingangen:</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href={`${base}nl/`} class="rounded bg-cannon-600 px-4 py-2 text-sm text-iron-950 hover:bg-cannon-500">Terug naar home</a>
      <a href={`${base}nl/mechanics/`} class="rounded border border-iron-700 px-4 py-2 text-sm text-iron-200 hover:border-cannon-600 hover:text-cannon-400">Bekijk mechanieken</a>
      <a href={`${base}nl/database/`} class="rounded border border-iron-700 px-4 py-2 text-sm text-iron-200 hover:border-cannon-600 hover:text-cannon-400">Bekijk database</a>
    </div>
  </section>
</BaseLayout>
