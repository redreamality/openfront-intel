---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import MapGrid from '../../../components/MapGrid.astro';
import maps from '../../../data/maps.json';

const order = ['Continental', 'Regional', 'Fantasy', 'Arcade', 'Tournament'] as const;
const groups = order.map((key) => {
  const cat = maps.meta.categories[key];
  return {
    key,
    label: cat.label,
    desc: cat.desc,
    items: maps.list.filter((m) => m.category === key),
  };
});
---

<BaseLayout title="Kaartenlijst" description="Alle kaarten van OpenFront.io gegroepeerd per categorie: Continentaal / Regionaal / Fantasy / Arcade / Tournament.">
  <PageHeader eyebrow="DATABASE / MAPS" title={`Kaartenlijst · ${maps.meta.total} kaarten`} lead="Gescand uit de officiële repository onder resources/maps, gegroepeerd op echte geografie en speelstijl." />
  <section class="container-wide py-10">
    <nav aria-label="Categorienavigatie" class="mb-8 flex flex-wrap gap-2">
      {groups.map((g) => (
        <a class="rounded border border-iron-800 px-3 py-1 text-xs text-iron-300 hover:border-cannon-600 hover:text-cannon-400" href={`#cat-${g.key.toLowerCase()}`}>
          {g.label} · {g.items.length}
        </a>
      ))}
    </nav>
    <MapGrid groups={groups} />
  </section>
</BaseLayout>
