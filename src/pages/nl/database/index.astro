---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import meta from '../../../data/_meta.json';
import maps from '../../../data/maps.json';
import units from '../../../data/units.json';
import structures from '../../../data/structures.json';

const base = import.meta.env.BASE_URL;
const sections = [
  { href: `${base}nl/database/units/`, title: 'Eenhedendatabase', desc: `Alle ${units.length} eenheden, voertuigen en projectielen, met kostenformules en opmerkingen.` },
  { href: `${base}nl/database/structures/`, title: 'Gebouwendatabase', desc: `${structures.length} structuren, met upgrademogelijkheden, bouwtijden en ontgrendelingsvoorwaarden.` },
  { href: `${base}nl/database/formulas/`, title: 'Snelle formuleoverzicht', desc: 'Kernformules voor gevecht, bevolkingslimiet, goudproductie en SAM-bereik.' },
  { href: `${base}nl/database/maps/`, title: 'Kaartenlijst', desc: `${maps.meta.total} kaarten gegroepeerd per categorie: Continentaal / Regionaal / Fantasy / Arcade / Tournament.` },
];
---

<BaseLayout title="Database" description="Snelle referentietabellen voor eenheden, gebouwen, kaarten en formules van OpenFront.io.">
  <PageHeader eyebrow="DATABASE" title="Database" lead="Alle cijfers worden gesynchroniseerd met de broncode van het spel, zodat je ze tijdens een partij snel kunt raadplegen." />
  <section class="container-wide py-10">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {sections.map((s) => (
        <a href={s.href} class="card group block">
          <h2 class="text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{s.title}</h2>
          <p class="mt-3 text-sm text-iron-300 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
    <p class="mt-10 text-xs text-iron-500 font-mono">Gegevens bijgewerkt op: {meta.generatedAt} · Bron: {meta.source.replace(/^.*OpenFrontIO.*/, 'OpenFrontIO ' + meta.upstreamVersion)}</p>
  </section>
</BaseLayout>
