---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import UnitTable from '../../../components/UnitTable.astro';
import Callout from '../../../components/Callout.astro';
import units from '../../../data/units.json';

type Unit = (typeof units)[number];
const groups: Array<{ key: Unit['category']; label: string; desc: string }> = [
  { key: 'structure', label: 'Gebouwen', desc: 'Constructies die je kunt bouwen, sommige zijn upgradeable voor sterkere eigenschappen.' },
  { key: 'ship', label: 'Schepen / voertuigen', desc: 'Transport- en gevechtseenheden over land en zee, inclusief treinen en handelsschepen.' },
  { key: 'nuke', label: 'Kernwapens', desc: 'AtomBomb, HydrogenBomb en MIRV: kosten en explosiestraal.' },
  { key: 'projectile', label: 'Munitie', desc: 'Projectielen die automatisch worden afgevuurd door gebouwen of eenheden.' },
];
---

<BaseLayout title="Eenhedendatabase" description="Snelle referentie voor alle 16 eenheden, gebouwen, voertuigen en munitie van OpenFront.io.">
  <PageHeader eyebrow="DATABASE / UNITS" title="Eenhedendatabase" lead="Gegroepeerd per categorie, met kostenformules, HP, schade en bouwduur. Klik op een rij voor een deelbare directe link." />
  <section class="container-wide py-10 space-y-12">
    <Callout type="spec" title="Leeswijzer">
      <p>In de kolom Kosten staat bovenaan de <strong>huidige eenheidsprijs</strong>, daaronder de <strong>kostenformule</strong> (n staat doorgaans voor het reeds gebouwde aantal).</p>
      <p>De bouwduur is uitgedrukt in <code>tick</code>; OpenFront.io draait op ongeveer <strong>10 ticks / seconde</strong>.</p>
      <p>Gebouwen met "upgrade" kunnen voor goud naar een hoger niveau gebracht worden; hoe hoger het niveau, hoe sterker het effect (bv. SAM-bereik, troops-limiet van een City).</p>
    </Callout>

    {groups.map((g) => {
      const items = units.filter((u) => u.category === g.key);
      if (items.length === 0) return null;
      return (
        <section id={`group-${g.key}`}>
          <header class="mb-4 flex flex-wrap items-baseline justify-between gap-3 border-b border-iron-800 pb-2">
            <h2 class="text-xl font-semibold text-iron-50">{g.label} <span class="text-sm text-iron-500">· {items.length}</span></h2>
            <p class="text-sm text-iron-400">{g.desc}</p>
          </header>
          <UnitTable units={items} showCategory={false} />
        </section>
      );
    })}
  </section>
</BaseLayout>
