---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import UnitTable from '../../../components/UnitTable.astro';
import Callout from '../../../components/Callout.astro';
import units from '../../../data/units.json';

type Unit = (typeof units)[number];
const groups: Array<{ key: Unit['category']; label: string; desc: string }> = [
  { key: 'structure', label: '建筑', desc: '可建造结构，部分可升级以增强属性。' },
  { key: 'ship', label: '船只 / 载具', desc: '海陆运输与战斗单位，含火车与贸易船。' },
  { key: 'nuke', label: '核武器', desc: '原子弹、氢弹、MIRV：成本与冲击范围。' },
  { key: 'projectile', label: '弹药', desc: '由建筑/单位自动发射的射弹。' },
];
---

<BaseLayout title="单位数据库" description="OpenFront.io 全 16 种单位 / 建筑 / 载具 / 弹药的数值速查。">
  <PageHeader eyebrow="DATABASE / UNITS" title="单位数据库" lead="按类别分组，含成本公式、HP、伤害、建造时长。点击表格行内 anchor 可分享直链。" />
  <section class="container-wide py-10 space-y-12">
    <Callout type="spec" title="读法约定">
      <p>成本一栏顶部是 <strong>当前单价</strong>，下方是 <strong>cost 公式</strong>（n 通常代表已建造数）。</p>
      <p>建造时长单位为 <code>tick</code>，OpenFront.io 约 <strong>10 ticks / 秒</strong>。</p>
      <p>「升级」标记的建筑可投入金币提升等级，等级越高效果越强（如 SAM 射程、城市部队上限）。</p>
    </Callout>

    {groups.map((g) => {
      const items = units.filter((u) => u.category === g.key);
      if (items.length === 0) return null;
      return (
        <section id={`group-${g.key}`}>
          <header class="mb-4 flex flex-wrap items-baseline justify-between gap-3 border-b border-iron-800 pb-2">
            <h2 class="text-xl font-semibold text-iron-50">{g.label} <span class="text-sm text-iron-500">· {items.length}</span></h2>
            <p class="text-sm text-iron-400">{g.desc}</p>
          </header>
          <UnitTable units={items} showCategory={false} />
        </section>
      );
    })}
  </section>
</BaseLayout>
