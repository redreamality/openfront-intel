---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import UnitTable from '../../../components/UnitTable.astro';
import Callout from '../../../components/Callout.astro';
import structures from '../../../data/structures.json';
---

<BaseLayout title="Gebouwendatabase" description="Gedetailleerde parameters van City, Port, Factory, DefensePost, SAM en MissileSilo.">
  <PageHeader eyebrow="DATABASE / STRUCTURES" title="Gebouwendatabase" lead="De 6 structuren met hun kosten, bouwtijden en upgrade-eigenschappen. De meeste gebouwen worden duurder naarmate hun aantal stijgt." />
  <section class="container-wide py-10 space-y-8">
    <Callout type="tip" title="Kosten temperen">
      <p>De kostenformule <code class="font-mono">min(1M, 2^n × 125k)</code> betekent dat de eerste 4 City/Port/Factory respectievelijk 125k → 250k → 500k → 1M kosten en daarna afgetopt zijn.</p>
      <p>Port en Factory <strong>delen dezelfde teller</strong> (PortBuildableGroup); de volgorde waarin je ze bouwt beïnvloedt hun prijs.</p>
    </Callout>
    <UnitTable units={structures} showCategory={false} />

    <section class="rounded border border-iron-800 bg-iron-900/40 p-5 text-sm leading-relaxed">
      <h2 class="text-base font-semibold text-cannon-400">Upgradeladder (4 niveaus)</h2>
      <ul class="mt-3 space-y-2 text-iron-300">
        <li><strong>City</strong> — <code class="font-mono">+250,000</code> troops-limiet per niveau; een hooggewaardeerde stad met een Factory geeft een merkbare boost aan de treinopbrengsten.</li>
        <li><strong>Port</strong> — hoe hoger het niveau, hoe hoger de <strong>spawnkans en de plafondopbrengst van handelsschepen</strong> (v24-balansing compenseert de globale cap van 150).</li>
        <li><strong>SAM Launcher</strong> — bereik stijgt van standaard 70 naar bijna 150 tiles, volgens de formule <code class="font-mono">150 − 480/(level+5)</code>.</li>
        <li><strong>Missile Silo</strong> — upgrades verkorten de laadtijd; AI vermijdt doelen onder SAM-dekking.</li>
        <li><strong>Factory</strong> — verhoogt de spawnsnelheid van treinen en de doorvoer van het spoornetwerk.</li>
      </ul>
    </section>
  </section>
</BaseLayout>
