---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import FormulaBlock from '../../../components/FormulaBlock.astro';
import Callout from '../../../components/Callout.astro';
import formulas from '../../../data/formulas.json';

const groups = Object.entries(formulas.groups);
---

<BaseLayout title="Snelle formuleoverzicht" description="Snelle referentie voor de kernformules van OpenFront.io: gevecht, bevolking, economie, kernwapens, allianties.">
  <PageHeader eyebrow="DATABASE / FORMULAS" title="Snelle formuleoverzicht" lead="Geen afleidingen, alleen conclusies. Alle formules zijn terug te vinden in OpenFrontIO/src/core/configuration/Config.ts." />
  <section class="container-wide py-10 space-y-6">
    <Callout type="warn" title="Leestips">
      <p>Formules gebruiken de variabelennamen van het spel (<code class="font-mono">tick</code>, <code class="font-mono">tiles</code>, <code class="font-mono">troops</code>).</p>
      <p>10 ticks ≈ 1 seconde. De constante <code class="font-mono">DEFENSE_DEBUFF_MIDPOINT = 150,000 tiles</code> komt rechtstreeks uit de broncode.</p>
    </Callout>
    {groups.map(([key, group]) => (
      <FormulaBlock label={group} items={group.items} />
    ))}
  </section>
</BaseLayout>
