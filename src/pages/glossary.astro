---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

interface Term {
  term: string;
  zh?: string;
  desc: string;
}
const sections: Array<{ key: string; label: string; terms: Term[] }> = [
  {
    key: 'general',
    label: 'General Terms',
    terms: [
      { term: 'tick', desc: 'Game time unit, ~0.1 seconds. 10 ticks = 1 second. All cooldowns and durations are in ticks.' },
      { term: 'Troops', zh: '部队', desc: 'Player-controlled population used for attack and defense.' },
      { term: 'MaxTroops', zh: '人口上限', desc: 'Troop growth ceiling, affected by tiles and City level.' },
      { term: 'Gold', zh: '金币', desc: 'Currency for building and upgrades. Base income 100/tick (Human) or 50/tick (Bot).' },
      { term: 'Attack Ratio', zh: '攻击比例', desc: 'Slider-controlled percentage of troops committed per attack.' },
      { term: 'tile', desc: 'Smallest map unit. "tiles" refers to territory count.' },
    ],
  },
  {
    key: 'units',
    label: 'Buildings & Units',
    terms: [
      { term: 'City', zh: '城市', desc: 'Each level +250,000 troop cap, also serves as train station.' },
      { term: 'Port', zh: '港口', desc: 'Spawns trade ships / transport ships / warships.' },
      { term: 'Factory', zh: '工厂', desc: 'Train production source, works with railways and cities.' },
      { term: 'DefensePost', zh: '防御工事', desc: '30 tiles range: mag ×5 / speed ×3.' },
      { term: 'SAM Launcher', zh: 'SAM 发射器', desc: 'Intercepts atom/hydrogen bombs, cannot intercept MIRV.' },
      { term: 'Missile Silo', zh: '导弹井', desc: 'Nuclear launch platform, 100 ticks build time.' },
      { term: 'Transport Ship', zh: '运输船', desc: 'Landing craft, vulnerable to warships.' },
      { term: 'Warship', zh: '战舰', desc: 'Naval control unit, HP 1000, Shell 250 damage.' },
      { term: 'Trade Ship', zh: '贸易船', desc: 'Auto-travels between ports for gold, v24 global cap 150.' },
      { term: 'Train', zh: '火车', desc: 'Land gold carrier, ally station visits yield 35k.' },
      { term: 'Atom Bomb', zh: '原子弹', desc: '750k gold, inner 12 / outer 30.' },
      { term: 'Hydrogen Bomb', zh: '氢弹', desc: '5M gold, inner 80 / outer 100.' },
      { term: 'MIRV', desc: '25M + 15M·n, multi-warhead carrier, SAM cannot intercept.' },
    ],
  },
  {
    key: 'mechanics',
    label: 'Mechanics Terms',
    terms: [
      { term: 'mag', desc: 'Armor penetration coefficient in combat. Terrain sets base, buildings multiply.' },
      { term: 'speed', desc: 'Advance rate coefficient. Like mag, affected by terrain and buildings.' },
      { term: 'Spawn Immunity', zh: '出生免疫', desc: '50 ticks of attack immunity after game starts.' },
      { term: 'Alliance', zh: '同盟', desc: '3000 ticks (5min), renewal prompt 300 ticks before expiry.' },
      { term: 'Betrayal', zh: '背叛', desc: 'Breaking alliance → defense ×0.5, speed ×0.8, lasts 300 ticks.' },
      { term: 'Embargo', zh: '禁运', desc: 'Blocks trade ships between parties. Temporary (attack-triggered) or permanent (manual).' },
      { term: 'Fallout', zh: '辐射区', desc: 'Radiation left in nuclear outer zone, temporarily weakens attacker mag.' },
      { term: 'Water Nukes', zh: '水核模式', desc: 'Allows nukes to affect ocean tiles with smooth circular damage.' },
      { term: 'Terrain Manipulation', zh: '地形操纵', desc: 'v24 new: affects adjacent tile terrain coefficients.' },
    ],
  },
  {
    key: 'meta',
    label: 'Players & Game Types',
    terms: [
      { term: 'Human', desc: 'Real player, troop cap ×1.0.' },
      { term: 'Nation', desc: 'System-named AI country, cap multiplied by difficulty.' },
      { term: 'Bot', desc: 'Basic AI, numbered names, troops ÷3.' },
      { term: 'FFA', desc: 'Free For All, 1 player per team.' },
      { term: 'Team', desc: '2v2 ~ 8v8 team battle, 5-minute victory condition.' },
      { term: 'Tournament', desc: 'Tournament-specific maps (Tourney1~4).' },
    ],
  },
];
---

<BaseLayout title="Glossary" description="OpenFront.io terminology with English-Chinese cross-reference.">
  <PageHeader eyebrow="GLOSSARY" title="Glossary" lead="Quick reference for unfamiliar concepts when reading mechanics and strategies. Includes Chinese translations." />
  <section class="container-wide py-10 space-y-10">
    {sections.map((s) => (
      <section id={s.key}>
        <h2 class="text-xl font-semibold text-iron-50 border-b border-iron-800 pb-2 mb-4">{s.label}</h2>
        <dl class="grid gap-3 sm:grid-cols-2">
          {s.terms.map((t) => (
            <div class="rounded border border-iron-800 bg-iron-900/40 px-4 py-3">
              <dt class="flex items-baseline gap-2">
                <span class="font-semibold text-cannon-400">{t.term}</span>
                {t.zh && <span class="font-mono text-xs text-iron-500">{t.zh}</span>}
              </dt>
              <dd class="mt-1 text-sm text-iron-300 leading-relaxed">{t.desc}</dd>
            </div>
          ))}
        </dl>
      </section>
    ))}
  </section>
</BaseLayout>
