---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

const base = import.meta.env.BASE_URL;
const sections = [
  { href: `${base}mechanics/basics/`, title: 'Basics: Spawn & Expansion', desc: 'Spawn immunity, phase duration, early decision framework.', tag: 'Basics' },
  { href: `${base}mechanics/economy/`, title: 'Economy: Gold, Trade & Population', desc: 'Base gold income, city troops, trade ships, train revenue.', tag: 'Economy' },
  { href: `${base}mechanics/military/`, title: 'Military: Combat & Defense', desc: 'Terrain modifiers, defense posts, population penalties, betrayal debuffs.', tag: 'Combat' },
  { href: `${base}mechanics/structures/`, title: 'Structures: 6 Core Buildings', desc: 'City / Port / Factory / DefensePost / SAM / Silo.', tag: 'Buildings' },
  { href: `${base}mechanics/units/`, title: 'Units: Ships, Vehicles & Projectiles', desc: 'Transport ships, warships, trade ships, trains, shells / SAM missiles.', tag: 'Units' },
  { href: `${base}mechanics/nukes/`, title: 'Nuclear Weapons & SAM', desc: 'AtomBomb / HydrogenBomb / MIRV and SAM interception networks.', tag: 'Nukes' },
  { href: `${base}mechanics/alliances/`, title: 'Alliances & Betrayal', desc: '5-minute alliances, auto-embargo, betrayal debuffs 0.5×0.8.', tag: 'Diplomacy' },
  { href: `${base}mechanics/trains/`, title: 'Trains & Railways', desc: 'v24 new mechanic: Factory → Train → City trade networks.', tag: 'New' },
  { href: `${base}mechanics/trade/`, title: 'Trade System', desc: 'Trade ship cap 150, distance revenue, embargo mercy timer.', tag: 'Economy' },
  { href: `${base}mechanics/modes/`, title: 'Game Modes Overview', desc: 'FFA / Duos / Trios / Quads / Team / Tournament.', tag: 'Overview' },
];
---

<BaseLayout title="Game Mechanics" description="All core OpenFront.io mechanics: 10 systematic topics from spawn to nuclear warfare.">
  <PageHeader eyebrow="MECHANICS" title="Game Mechanics" lead="10 chapters organized by system, all values from v24 source code. Start with Basics and Economy." />
  <section class="container-wide py-10">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sections.map((s, i) => (
        <a href={s.href} class="card group block">
          <div class="flex items-center justify-between text-xs">
            <span class="font-mono text-iron-500">{String(i + 1).padStart(2, '0')}</span>
            <span class="tag-chip">{s.tag}</span>
          </div>
          <h2 class="mt-3 text-lg font-semibold text-cannon-400 group-hover:text-cannon-300">{s.title}</h2>
          <p class="mt-2 text-sm text-iron-300 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
